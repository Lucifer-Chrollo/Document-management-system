@using DocumentManagementSystem.Models
@using DocumentManagementSystem.Services
@using System.Security.Claims
@inject IUploadSessionService UploadSessionService
@inject NavigationManager Navigation
@inject NotificationService NotificationService
@inject AuthenticationStateProvider AuthStateProvider
@inject IHttpContextAccessor HttpContextAccessor
@inject IDocumentService DocumentService

<RadzenCard Style="margin-bottom: 1.5rem;">
    <RadzenStack Gap="1rem">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
             <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                <RadzenIcon Icon="qr_code_2" Style="color: var(--rz-primary);" />
                <RadzenText TextStyle="TextStyle.Subtitle2" Style="margin: 0;">Mobile Upload</RadzenText>
            </RadzenStack>
             @if (activeSessionsCount > 0)
             {
                 <RadzenBadge BadgeStyle="BadgeStyle.Info" Text="@activeSessionsCount.ToString()" />
             }
        </RadzenStack>

        @if (isLoading)
        {
             <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Small" />
        }
        else if (showQrCode)
        {
            <!-- QR View -->
            <RadzenStack AlignItems="AlignItems.Center" Gap="0.5rem">
                <img src="@qrCodeUrl" alt="QR Code" style="border: 1px solid #ddd; padding: 5px; border-radius: 4px; width: 100%; max-width: 150px;" />
                
                <RadzenStack Gap="0" AlignItems="AlignItems.Center" Style="width: 100%; background: #f8f9fa; padding: 0.5rem; border-radius: 4px;">
                    <RadzenText TextStyle="TextStyle.Caption" class="text-muted">PIN Code</RadzenText>
                    <RadzenText TextStyle="TextStyle.H6" Style="margin: 0; font-family: monospace; letter-spacing: 2px;">@generatedPin</RadzenText>
                </RadzenStack>

                <RadzenText TextStyle="TextStyle.Caption" class="text-muted" TextAlign="TextAlign.Center">
                    Scan to upload. Expires in @createdExpiry min.
                </RadzenText>
                
                <RadzenButton Text="Done" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Light" Click="@ResetView" Style="width: 100%;" />
            </RadzenStack>
        }
        else if (isCreating)
        {
            <!-- Setup View -->
            <RadzenStack Gap="0.5rem">
                <RadzenText TextStyle="TextStyle.Caption">Session Duration</RadzenText>
                <RadzenDropDown @bind-Value="@expiryMinutes" Data="@expiryOptions" TextProperty="Text" ValueProperty="Value" Style="width: 100%;" />
                
                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" Style="margin-top: 5px;">
                     <RadzenButton Icon="close" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Light" Click="@(() => isCreating = false)" />
                     <RadzenButton Text="Generate" Size="ButtonSize.Small" Icon="qr_code" ButtonStyle="ButtonStyle.Primary" Click="@GenerateSession" IsBusy="@isGenerating" Style="flex: 1;" />
                </RadzenStack>
            </RadzenStack>
        }
        else
        {
            <!-- Default View -->
            <RadzenButton Text="New Session" Size="ButtonSize.Small" Icon="add_link" ButtonStyle="ButtonStyle.Primary" Click="@(() => isCreating = true)" />
            
            @if (activeSessions.Any())
            {
                <RadzenStack Gap="0.5rem" Style="max-height: 150px; overflow-y: auto;">
                    @foreach (var s in activeSessions)
                    {
                        <RadzenCard Style="padding: 0.5rem; border: 1px solid #eee;">
                            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
                                <RadzenStack Gap="0">
                                    <RadzenText TextStyle="TextStyle.Caption" Style="font-weight: bold;">@s.Label</RadzenText>
                                    <RadzenText TextStyle="TextStyle.Caption" class="text-muted">
                                        @s.FilesUploaded files
                                    </RadzenText>
                                </RadzenStack>
                                <RadzenButton Icon="block" Size="ButtonSize.ExtraSmall" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Text" Click="@(() => RevokeSession(s.SessionId))" />
                            </RadzenStack>
                        </RadzenCard>
                    }
                </RadzenStack>
            }
        }
    </RadzenStack>
</RadzenCard>
