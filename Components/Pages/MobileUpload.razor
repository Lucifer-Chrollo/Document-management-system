@page "/m/upload/{Token}"
@layout DocumentManagementSystem.Components.Layout.EmptyLayout
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@using DocumentManagementSystem.Models
@using DocumentManagementSystem.Services
@inject IUploadSessionService UploadSessionService
@inject IDocumentService DocumentService
@inject NavigationManager Navigation
@inject IHttpContextAccessor HttpContextAccessor

<PageTitle>Mobile Upload - DMS</PageTitle>

<style>
    .mobile-container {
        min-height: 100vh;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 1rem;
    }
    .upload-card {
        background: white;
        border-radius: 16px;
        padding: 1.5rem;
        max-width: 400px;
        margin: 0 auto;
        box-shadow: 0 10px 40px rgba(0,0,0,0.2);
    }
    .pin-input {
        font-size: 2rem !important;
        text-align: center;
        letter-spacing: 0.5rem;
        font-family: monospace;
    }
    .file-input-wrapper {
        border: 2px dashed #ccc;
        border-radius: 12px;
        padding: 2rem;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s;
    }
    .file-input-wrapper:hover {
        border-color: #667eea;
        background: #f8f9ff;
    }
    .success-icon {
        font-size: 4rem;
        color: #22c55e;
    }
    .error-icon {
        font-size: 4rem;
        color: #ef4444;
    }
</style>

<div class="mobile-container">
    <div class="upload-card">
        @if (isLoading)
        {
            <RadzenStack AlignItems="AlignItems.Center" Gap="1rem" Style="padding: 2rem;">
                <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Large" />
                <RadzenText>Loading...</RadzenText>
            </RadzenStack>
        }
        else if (session == null || !session.IsActive)
        {
            <!-- Invalid/Expired Session -->
            <RadzenStack AlignItems="AlignItems.Center" Gap="1rem">
                <RadzenIcon Icon="error_outline" class="error-icon" />
                <RadzenText TextStyle="TextStyle.H5" TextAlign="TextAlign.Center">Session Invalid</RadzenText>
                <RadzenText class="text-muted text-center">
                    This upload link is invalid, expired, or has been revoked.
                </RadzenText>
            </RadzenStack>
        }
        else if (DateTime.UtcNow >= session.ExpiresAt)
        {
            <!-- Expired -->
            <RadzenStack AlignItems="AlignItems.Center" Gap="1rem">
                <RadzenIcon Icon="timer_off" class="error-icon" />
                <RadzenText TextStyle="TextStyle.H5" TextAlign="TextAlign.Center">Session Expired</RadzenText>
                <RadzenText class="text-muted text-center">
                    This upload session has expired. Please request a new QR code.
                </RadzenText>
            </RadzenStack>
        }
        else if (session.FailedAttempts >= session.MaxAttempts)
        {
            <!-- Locked Out -->
            <RadzenStack AlignItems="AlignItems.Center" Gap="1rem">
                <RadzenIcon Icon="lock" class="error-icon" />
                <RadzenText TextStyle="TextStyle.H5" TextAlign="TextAlign.Center">Session Locked</RadzenText>
                <RadzenText class="text-muted text-center">
                    Too many incorrect PIN attempts. This session has been locked.
                </RadzenText>
            </RadzenStack>
        }
        else if (!isPinVerified)
        {
            <!-- PIN Verification -->
            <RadzenStack AlignItems="AlignItems.Center" Gap="1.5rem">
                <RadzenIcon Icon="security" Style="font-size: 3rem; color: #667eea;" />
                <RadzenText TextStyle="TextStyle.H5" TextAlign="TextAlign.Center">Enter PIN</RadzenText>
                <RadzenText class="text-muted text-center">
                    Enter the 6-digit PIN shown when the QR code was generated.
                </RadzenText>

                @if (!string.IsNullOrEmpty(pinError))
                {
                    <RadzenAlert AlertStyle="AlertStyle.Danger" Shade="Shade.Lighter">
                        @pinError
                    </RadzenAlert>
                }

                <RadzenTextBox @bind-Value="@enteredPin" Placeholder="000000" MaxLength="6"
                               class="pin-input" Style="width: 180px;" />

                <RadzenText class="text-muted" Style="font-size: 0.8rem;">
                    Attempts remaining: @(session.MaxAttempts - session.FailedAttempts)
                </RadzenText>

                <RadzenButton Text="Verify" Icon="check" ButtonStyle="ButtonStyle.Primary" 
                              Style="width: 100%;" Click="@VerifyPin" IsBusy="@isVerifying" />
            </RadzenStack>
        }
        else if (uploadSuccess)
        {
            <!-- Upload Success -->
            <RadzenStack AlignItems="AlignItems.Center" Gap="1rem">
                <RadzenIcon Icon="check_circle" class="success-icon" />
                <RadzenText TextStyle="TextStyle.H5" TextAlign="TextAlign.Center">Upload Complete!</RadzenText>
                <RadzenText class="text-muted text-center">
                    @uploadedCount file(s) uploaded successfully to @session.UserName's account.
                </RadzenText>
                
                <RadzenButton Text="Upload More" Icon="add" ButtonStyle="ButtonStyle.Primary" 
                                Style="width: 100%;" Click="@(() => uploadSuccess = false)" />
            </RadzenStack>
        }
        else
        {
            <!-- Upload Form -->
            <RadzenStack Gap="1.5rem">
                <RadzenStack AlignItems="AlignItems.Center" Gap="0.5rem">
                    <RadzenIcon Icon="cloud_upload" Style="font-size: 2.5rem; color: #667eea;" />
                    <RadzenText TextStyle="TextStyle.H5" TextAlign="TextAlign.Center">Upload Files</RadzenText>
                    <RadzenText class="text-muted text-center">
                        Uploading as <strong>@session.UserName</strong>
                    </RadzenText>
                </RadzenStack>

                <!-- Session Info -->
                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceAround">
                    <RadzenStack AlignItems="AlignItems.Center">
                        <RadzenText Style="font-size: 0.8rem; color: #888;">Time Left</RadzenText>
                        <RadzenText Style="font-weight: bold;">@session.RemainingMinutes min</RadzenText>
                    </RadzenStack>
                    <RadzenStack AlignItems="AlignItems.Center">
                        <RadzenText Style="font-size: 0.8rem; color: #888;">Files Uploaded</RadzenText>
                        <RadzenText Style="font-weight: bold;">@session.FilesUploaded</RadzenText>
                    </RadzenStack>
                </RadzenStack>

                @if (!string.IsNullOrEmpty(uploadError))
                {
                    <RadzenAlert AlertStyle="AlertStyle.Danger" Shade="Shade.Lighter">
                        @uploadError
                    </RadzenAlert>
                }

                <!-- File Input -->
                <div class="file-input-wrapper">
                    <InputFile OnChange="@HandleFileSelected" multiple accept="*/*" style="display: none;" id="fileInput" />
                    <label for="fileInput" style="cursor: pointer; width: 100%; display: block;">
                        <RadzenIcon Icon="add_photo_alternate" Style="font-size: 3rem; color: #667eea;" />
                        <RadzenText>Tap to select files</RadzenText>
                        <RadzenText class="text-muted" Style="font-size: 0.8rem;">or use camera</RadzenText>
                    </label>
                </div>

                @if (selectedFiles.Any())
                {
                    <RadzenStack Gap="0.5rem">
                        @foreach (var file in selectedFiles)
                        {
                            <RadzenCard Style="padding: 0.5rem;">
                                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
                                    <RadzenText Style="font-size: 0.9rem; overflow: hidden; text-overflow: ellipsis;">
                                        @file.Name
                                    </RadzenText>
                                    <RadzenText class="text-muted" Style="font-size: 0.8rem;">
                                        @FormatSize(file.Size)
                                    </RadzenText>
                                </RadzenStack>
                            </RadzenCard>
                        }

                        <RadzenButton Text="@($"Upload {selectedFiles.Count} File(s)")" Icon="cloud_upload" 
                                      ButtonStyle="ButtonStyle.Success" Style="width: 100%;" 
                                      Click="@UploadFiles" IsBusy="@isUploading" />
                    </RadzenStack>
                }

                @if (!string.IsNullOrEmpty(session.Label))
                {
                    <RadzenText class="text-muted text-center" Style="font-size: 0.85rem;">
                        Session: @session.Label
                    </RadzenText>
                }
            </RadzenStack>
        }
    </div>
</div>
