@page "/m/upload/{Token}"
@layout DocumentManagementSystem.Components.Layout.EmptyLayout
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@using DocumentManagementSystem.Models
@using DocumentManagementSystem.Services
@inject IUploadSessionService UploadSessionService
@inject IDocumentService DocumentService
@inject NavigationManager Navigation
@inject IHttpContextAccessor HttpContextAccessor
@inject IJSRuntime JS

<PageTitle>Mobile Upload - DMS</PageTitle>

<style>
    .mobile-container {
        min-height: 100vh;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 1rem;
    }
    .upload-card {
        background: white;
        border-radius: 16px;
        padding: 1.5rem;
        max-width: 400px;
        margin: 0 auto;
        box-shadow: 0 10px 40px rgba(0,0,0,0.2);
    }
    .pin-input {
        font-size: 2rem !important;
        text-align: center;
        letter-spacing: 0.5rem;
        font-family: monospace;
    }
    .file-input-wrapper {
        border: 2px dashed #ccc;
        border-radius: 12px;
        padding: 2rem;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s;
    }
    .file-input-wrapper:hover {
        border-color: #667eea;
        background: #f8f9ff;
    }
    .success-icon {
        font-size: 4rem;
        color: #22c55e;
    }
    .error-icon {
        font-size: 4rem;
        color: #ef4444;
    }
    .file-queue-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.4rem 0.6rem;
        background: #f9f9f9;
        border-radius: 8px;
        margin-bottom: 0.3rem;
    }
    .file-queue-item .file-name {
        font-size: 0.85rem;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        flex: 1;
        margin-right: 0.5rem;
    }
    .file-queue-item .file-size {
        font-size: 0.75rem;
        color: #888;
        white-space: nowrap;
        margin-right: 0.5rem;
    }
    .file-queue-item .remove-btn {
        background: none;
        border: none;
        color: #dc3545;
        cursor: pointer;
        font-size: 1.2rem;
        padding: 0;
        line-height: 1;
    }
    .add-more-btn {
        cursor: pointer;
        text-align: center;
        padding: 0.6rem;
        border: 1px dashed #667eea;
        border-radius: 8px;
        color: #667eea;
        font-size: 0.9rem;
        margin-top: 0.5rem;
        display: block;
    }
    .upload-progress {
        margin-top: 0.5rem;
        font-size: 0.85rem;
        text-align: center;
        color: #667eea;
    }
</style>

<div class="mobile-container">
    <div class="upload-card">
        @if (isLoading)
        {
            <RadzenStack AlignItems="AlignItems.Center" Gap="1rem" Style="padding: 2rem;">
                <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Large" />
                <RadzenText>Loading...</RadzenText>
            </RadzenStack>
        }
        else if (session == null || !session.IsActive)
        {
            <!-- Invalid/Expired Session -->
            <RadzenStack AlignItems="AlignItems.Center" Gap="1rem">
                <RadzenIcon Icon="error_outline" class="error-icon" />
                <RadzenText TextStyle="TextStyle.H5" TextAlign="TextAlign.Center">Session Invalid</RadzenText>
                <RadzenText class="text-muted text-center">
                    This upload link is invalid, expired, or has been revoked.
                </RadzenText>
            </RadzenStack>
        }
        else if (DateTime.UtcNow >= session.ExpiresAt)
        {
            <!-- Expired -->
            <RadzenStack AlignItems="AlignItems.Center" Gap="1rem">
                <RadzenIcon Icon="timer_off" class="error-icon" />
                <RadzenText TextStyle="TextStyle.H5" TextAlign="TextAlign.Center">Session Expired</RadzenText>
                <RadzenText class="text-muted text-center">
                    This upload session has expired. Please request a new QR code.
                </RadzenText>
            </RadzenStack>
        }
        else if (session.FailedAttempts >= session.MaxAttempts)
        {
            <!-- Locked Out -->
            <RadzenStack AlignItems="AlignItems.Center" Gap="1rem">
                <RadzenIcon Icon="lock" class="error-icon" />
                <RadzenText TextStyle="TextStyle.H5" TextAlign="TextAlign.Center">Session Locked</RadzenText>
                <RadzenText class="text-muted text-center">
                    Too many incorrect PIN attempts. This session has been locked.
                </RadzenText>
            </RadzenStack>
        }
        else if (!isPinVerified)
        {
            <!-- PIN Verification -->
            <RadzenStack AlignItems="AlignItems.Center" Gap="1.5rem">
                <RadzenIcon Icon="security" Style="font-size: 3rem; color: #667eea;" />
                <RadzenText TextStyle="TextStyle.H5" TextAlign="TextAlign.Center">Enter PIN</RadzenText>
                <RadzenText class="text-muted text-center">
                    Enter the 6-digit PIN shown when the QR code was generated.
                </RadzenText>

                @if (!string.IsNullOrEmpty(pinError))
                {
                    <RadzenAlert AlertStyle="AlertStyle.Danger" Shade="Shade.Lighter">
                        @pinError
                    </RadzenAlert>
                }

                <RadzenTextBox @bind-Value="@enteredPin" Placeholder="000000" MaxLength="6"
                               class="pin-input" Style="width: 180px;" />

                <RadzenText class="text-muted" Style="font-size: 0.8rem;">
                    Attempts remaining: @(session.MaxAttempts - session.FailedAttempts)
                </RadzenText>

                <RadzenButton Text="Verify" Icon="check" ButtonStyle="ButtonStyle.Primary" 
                              Style="width: 100%;" Click="@VerifyPin" IsBusy="@isVerifying" />
            </RadzenStack>
        }
        else if (uploadSuccess)
        {
            <!-- Upload Success -->
            <RadzenStack AlignItems="AlignItems.Center" Gap="1rem">
                <RadzenIcon Icon="check_circle" class="success-icon" />
                <RadzenText TextStyle="TextStyle.H5" TextAlign="TextAlign.Center">Upload Complete!</RadzenText>
                <RadzenText class="text-muted text-center">
                    @uploadedCount file(s) uploaded successfully to @session.UserName's account.
                </RadzenText>
                
                <RadzenButton Text="Upload More" Icon="add" ButtonStyle="ButtonStyle.Primary" 
                                Style="width: 100%;" Click="@(() => { uploadSuccess = false; StateHasChanged(); })" />
            </RadzenStack>
        }
        else
        {
            <!-- Upload Form -->
            <RadzenStack Gap="1.5rem">
                <RadzenStack AlignItems="AlignItems.Center" Gap="0.5rem">
                    <RadzenIcon Icon="cloud_upload" Style="font-size: 2.5rem; color: #667eea;" />
                    <RadzenText TextStyle="TextStyle.H5" TextAlign="TextAlign.Center">Upload Files</RadzenText>
                    <RadzenText class="text-muted text-center">
                        Uploading as <strong>@session.UserName</strong>
                    </RadzenText>
                </RadzenStack>

                <!-- Session Info -->
                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceAround">
                    <RadzenStack AlignItems="AlignItems.Center">
                        <RadzenText Style="font-size: 0.8rem; color: #888;">Time Left</RadzenText>
                        <RadzenText Style="font-weight: bold;">@session.RemainingMinutes min</RadzenText>
                    </RadzenStack>
                    <RadzenStack AlignItems="AlignItems.Center">
                        <RadzenText Style="font-size: 0.8rem; color: #888;">Files Uploaded</RadzenText>
                        <RadzenText Style="font-weight: bold;">@session.FilesUploaded</RadzenText>
                    </RadzenStack>
                </RadzenStack>

                @if (!string.IsNullOrEmpty(uploadError))
                {
                    <RadzenAlert AlertStyle="AlertStyle.Danger" Shade="Shade.Lighter">
                        @uploadError
                    </RadzenAlert>
                }

                <!-- Native HTML file input (bypasses Blazor SignalR circuit) -->
                <input type="file" id="mobileFileInput" multiple 
                       style="display: none;" onchange="window.mobileUpload.onFilesSelected()" />
                
                <div class="file-input-wrapper" onclick="document.getElementById('mobileFileInput').click()">
                    <RadzenIcon Icon="add_photo_alternate" Style="font-size: 3rem; color: #667eea;" />
                    <p style="margin: 0.5rem 0 0 0;">Tap to select files</p>
                    <p style="margin: 0; font-size: 0.8rem; color: #888;">Select multiple files at once, or tap again to add more</p>
                </div>

                <!-- File queue (rendered by JS, managed by Blazor) -->
                <div id="fileQueueContainer">
                    @if (fileCount > 0)
                    {
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
                            <strong style="font-size: 0.9rem;">@fileCount file(s) queued</strong>
                            <button onclick="window.mobileUpload.clearAll()" 
                                    style="background: none; border: none; color: #dc3545; cursor: pointer; font-size: 0.85rem;">
                                ✕ Clear All
                            </button>
                        </div>
                        
                        <div id="fileListDisplay" style="max-height: 200px; overflow-y: auto;"></div>
                        
                        <label class="add-more-btn" onclick="document.getElementById('mobileFileInput').click()">
                            + Add More Files
                        </label>
                        
                        @if (isUploading)
                        {
                            <div class="upload-progress">
                                <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Small" />
                                <p>Uploading... @uploadedCount / @fileCount</p>
                            </div>
                        }
                        else
                        {
                            <button onclick="window.mobileUpload.uploadAll()"
                                    style="width: 100%; padding: 0.75rem; background: #22c55e; color: white; border: none; border-radius: 8px; font-size: 1rem; cursor: pointer; margin-top: 0.5rem;">
                                ☁ Upload @fileCount File(s)
                            </button>
                        }
                    }
                </div>

                @if (!string.IsNullOrEmpty(session.Label))
                {
                    <RadzenText class="text-muted text-center" Style="font-size: 0.85rem;">
                        Session: @session.Label
                    </RadzenText>
                }
            </RadzenStack>
        }
    </div>
</div>

<script suppress-error="BL9992">
    window.mobileUpload = {
        files: [],
        
        onFilesSelected: function() {
            var input = document.getElementById('mobileFileInput');
            for (var i = 0; i < input.files.length; i++) {
                this.files.push(input.files[i]);
            }
            // Reset input so the same files can be re-selected
            input.value = '';
            this.renderFileList();
            // Notify Blazor of the new file count
            DotNet.invokeMethodAsync('DocumentManagementSystem', 'UpdateFileCount', this.files.length);
        },
        
        removeFile: function(index) {
            this.files.splice(index, 1);
            this.renderFileList();
            DotNet.invokeMethodAsync('DocumentManagementSystem', 'UpdateFileCount', this.files.length);
        },
        
        clearAll: function() {
            this.files = [];
            this.renderFileList();
            DotNet.invokeMethodAsync('DocumentManagementSystem', 'UpdateFileCount', 0);
        },
        
        renderFileList: function() {
            var container = document.getElementById('fileListDisplay');
            if (!container) return;
            
            var html = '';
            for (var i = 0; i < this.files.length; i++) {
                var file = this.files[i];
                var size = file.size < 1024 ? file.size + ' B' : 
                           file.size < 1024 * 1024 ? (file.size / 1024).toFixed(1) + ' KB' : 
                           (file.size / (1024 * 1024)).toFixed(1) + ' MB';
                html += '<div class="file-queue-item">' +
                    '<span class="file-name">' + this.escapeHtml(file.name) + '</span>' +
                    '<span class="file-size">' + size + '</span>' +
                    '<button class="remove-btn" onclick="window.mobileUpload.removeFile(' + i + ')">✕</button>' +
                    '</div>';
            }
            container.innerHTML = html;
        },
        
        escapeHtml: function(text) {
            var div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        },
        
        uploadAll: async function() {
            if (this.files.length === 0) return;
            
            var token = '@Token';
            var formData = new FormData();
            for (var i = 0; i < this.files.length; i++) {
                formData.append('files', this.files[i]);
            }
            
            DotNet.invokeMethodAsync('DocumentManagementSystem', 'SetUploadingState', true);
            
            try {
                var response = await fetch('/api/MobileUpload/upload/' + token, {
                    method: 'POST',
                    body: formData
                });
                
                var result = await response.json();
                
                if (result.success) {
                    this.files = [];
                    this.renderFileList();
                    DotNet.invokeMethodAsync('DocumentManagementSystem', 'OnUploadComplete', result.uploaded, '');
                } else {
                    var errors = result.results ? result.results.filter(r => !r.success).map(r => r.name + ': ' + r.error).join('\n') : 'Upload failed';
                    DotNet.invokeMethodAsync('DocumentManagementSystem', 'OnUploadComplete', result.uploaded || 0, errors);
                }
            } catch (err) {
                DotNet.invokeMethodAsync('DocumentManagementSystem', 'OnUploadComplete', 0, 'Network error: ' + err.message);
            }
        }
    };
</script>
