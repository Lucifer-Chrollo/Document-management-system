@page "/admin/audit"
@using DocumentManagementSystem.Models
@using DocumentManagementSystem.Services
@inject IAuditService AuditService
@inject NavigationManager Navigation
@inject NotificationService NotificationService

<PageTitle>Audit Logs - DMS</PageTitle>

<RadzenStack Gap="0.5rem" class="p-2 fade-in-up">
    <!-- Header Area -->
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
            <RadzenIcon Icon="receipt_long" Style="font-size: 1.5rem; color: #0071c1;" />
            <RadzenText TextStyle="TextStyle.H5" class="pagetitle-fontsize" Style="margin: 0; font-weight: bold;">Audit Trail</RadzenText>
        </RadzenStack>
        <RadzenButton Text="Refresh" Icon="refresh" Click="@LoadLogs" ButtonStyle="ButtonStyle.Light" class="search-button" />
    </RadzenStack>

    <!-- Stats Cards -->
    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12" SizeMD="2">
            <RadzenCard class="h-100">
                <RadzenStack AlignItems="AlignItems.Center">
                    <RadzenText TextStyle="TextStyle.H4" class="mb-0">@stats.TotalActions</RadzenText>
                    <RadzenText class="text-muted" Style="font-size: 0.8rem;">Total Actions</RadzenText>
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="6" SizeMD="2">
            <RadzenCard class="h-100">
                <RadzenStack AlignItems="AlignItems.Center">
                    <RadzenText TextStyle="TextStyle.H4" class="mb-0" Style="color: var(--rz-info);">@stats.ViewCount</RadzenText>
                    <RadzenText class="text-muted" Style="font-size: 0.8rem;">Views</RadzenText>
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="6" SizeMD="2">
            <RadzenCard class="h-100">
                <RadzenStack AlignItems="AlignItems.Center">
                    <RadzenText TextStyle="TextStyle.H4" class="mb-0" Style="color: var(--rz-success);">@stats.DownloadCount</RadzenText>
                    <RadzenText class="text-muted" Style="font-size: 0.8rem;">Downloads</RadzenText>
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="6" SizeMD="2">
            <RadzenCard class="h-100">
                <RadzenStack AlignItems="AlignItems.Center">
                    <RadzenText TextStyle="TextStyle.H4" class="mb-0" Style="color: var(--rz-warning);">@stats.CreateCount</RadzenText>
                    <RadzenText class="text-muted" Style="font-size: 0.8rem;">Created</RadzenText>
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="6" SizeMD="2">
            <RadzenCard class="h-100">
                <RadzenStack AlignItems="AlignItems.Center">
                    <RadzenText TextStyle="TextStyle.H4" class="mb-0" Style="color: var(--rz-danger);">@stats.DeleteCount</RadzenText>
                    <RadzenText class="text-muted" Style="font-size: 0.8rem;">Deleted</RadzenText>
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="6" SizeMD="2">
            <RadzenCard class="h-100">
                <RadzenStack AlignItems="AlignItems.Center">
                    <RadzenText TextStyle="TextStyle.H4" class="mb-0">@stats.UniqueUsers</RadzenText>
                    <RadzenText class="text-muted" Style="font-size: 0.8rem;">Users</RadzenText>
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>

    <!-- Filters -->
    <div class="card-body-D px-1 py-1">
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0" AlignItems="AlignItems.Center" Style="flex-wrap: nowrap;" class="zero-gap-stack">
            <RadzenDropDown @bind-Value="@filterAction" Data="@actionTypes" Placeholder="Action..." 
                            Style="width: 150px;" AllowClear="true" />
            <RadzenDatePicker @bind-Value="@filterFromDate" DateFormat="yyyy-MM-dd" Placeholder="From" Style="width: 130px;" Popup="true" Inline="false" />
            <RadzenDatePicker @bind-Value="@filterToDate" DateFormat="yyyy-MM-dd" Placeholder="To" Style="width: 130px;" Popup="true" Inline="false" />
            <RadzenButton Text="Search" Icon="filter_list" Click="@LoadLogs" class="search-button" />
            <RadzenButton Text="Clear" Icon="clear" ButtonStyle="ButtonStyle.Light" Click="@ClearFilters" class="search-button" />
        </RadzenStack>
    </div>

    <!-- Logs Grid -->
    <RadzenCard>
        @if (isLoading)
        {
            <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Style="min-height: 200px;">
                <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Large" />
                <RadzenText>Loading audit logs...</RadzenText>
            </RadzenStack>
        }
        else
        {
            <RadzenDataGrid Data="@logs" TItem="AuditLog" AllowFiltering="false" AllowSorting="true" 
                            AllowPaging="true" PageSize="20" PagerHorizontalAlign="HorizontalAlign.Center"
                            FilterMode="FilterMode.Simple" Density="Density.Compact">
                <Columns>
                    <RadzenDataGridColumn TItem="AuditLog" Property="Timestamp" Title="Time" Width="160px" 
                                          FormatString="{0:MMM dd, yyyy HH:mm}" />
                    <RadzenDataGridColumn TItem="AuditLog" Property="Action" Title="Action" Width="120px">
                        <Template Context="log">
                            <RadzenBadge BadgeStyle="@GetActionBadgeStyle(log.Action)" Text="@log.Action" />
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="AuditLog" Property="DocumentName" Title="Document" Width="250px">
                        <Template Context="log">
                            @if (log.DocumentId.HasValue)
                            {
                                <RadzenLink Path="@($"/document/{log.DocumentId}")" Text="@(log.DocumentName ?? $"Doc #{log.DocumentId}")" />
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="AuditLog" Property="UserName" Title="User" Width="150px" />
                    <RadzenDataGridColumn TItem="AuditLog" Property="IpAddress" Title="IP" Width="120px" />
                    <RadzenDataGridColumn TItem="AuditLog" Property="Success" Title="Status" Width="80px" TextAlign="TextAlign.Center">
                        <Template Context="log">
                            @if (log.Success)
                            {
                                <RadzenIcon Icon="check_circle" Style="color: var(--rz-success);" />
                            }
                            else
                            {
                                <RadzenIcon Icon="error" Style="color: var(--rz-danger);" title="@log.ErrorMessage" />
                            }
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="AuditLog" Property="Details" Title="Details" Width="200px">
                        <Template Context="log">
                            <span style="font-size: 0.85rem; color: var(--rz-text-secondary);">
                                @TruncateDetails(log.Details)
                            </span>
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        }
    </RadzenCard>
</RadzenStack>
