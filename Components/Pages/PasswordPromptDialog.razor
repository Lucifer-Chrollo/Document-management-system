@using Radzen
@using Radzen.Blazor
@inject Radzen.DialogService DialogService

<RadzenStack Gap="1.5rem" Style="padding: 1rem;">
    <RadzenText TextStyle="TextStyle.Subtitle1" Style="font-weight: 500;">
        This document is protected. Please enter the password to continue.
    </RadzenText>

    <RadzenPassword @bind-Value="password" Style="width: 100%; display: block;" 
                    Placeholder="Enter document password" 
                    @onkeyup="@(e => { if (e.Key == "Enter") Submit(); })" />

    @if (showError)
    {
        <RadzenText TextStyle="TextStyle.Caption" Style="color: #d32f2f;">
            @errorMessage
        </RadzenText>
    }

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
        <RadzenButton Text="Cancel" Click="Cancel" ButtonStyle="ButtonStyle.Light" />
        <RadzenButton Text="Submit" Click="Submit" ButtonStyle="ButtonStyle.Primary" Disabled="@string.IsNullOrWhiteSpace(password)" />
    </RadzenStack>
</RadzenStack>
