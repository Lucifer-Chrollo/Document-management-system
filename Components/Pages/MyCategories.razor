@page "/ManageCategories"
@using DocumentManagementSystem.Models
@using DocumentManagementSystem.Services
@inject ICategoryService CategoryService
@inject NotificationService NotificationService
@inject DialogService DialogService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<PageTitle>My Categories - DMS</PageTitle>

<RadzenStack Gap="1rem" Style="padding: 1rem;">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
            <RadzenIcon Icon="category" Style="font-size: 1.5rem; color: #0071c1;" />
            <RadzenText TextStyle="TextStyle.H5" class="pagetitle-fontsize m-0">My Categories</RadzenText>
        </RadzenStack>
        <RadzenButton Icon="add" Text="New Category" ButtonStyle="ButtonStyle.Success" Click="@OnCreateCategory" />
    </RadzenStack>

    <RadzenDataGrid Data="@categories" TItem="Category" IsLoading="@isLoading"
                    AllowSorting="true" AllowPaging="true" PageSize="15"
                    Style="border: 1px solid #ccc;">
        <Columns>
            <RadzenDataGridColumn TItem="Category" Property="CategoryId" Title="ID" Width="70px" TextAlign="TextAlign.Center" />
            <RadzenDataGridColumn TItem="Category" Property="CategoryName" Title="Name" Width="250px" />
            <RadzenDataGridColumn TItem="Category" Property="Description" Title="Description" />
            <RadzenDataGridColumn TItem="Category" Property="CreatedDate" Title="Created" Width="160px">
                <Template Context="cat">
                    @cat.CreatedDate.ToString("MMM dd, yyyy")
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Category" Title="Actions" Width="140px" TextAlign="TextAlign.Center" Sortable="false">
                <Template Context="cat">
                    <RadzenButton Image="edit-icon.png" ButtonStyle="ButtonStyle.Secondary" Size="ButtonSize.Small" Variant="Variant.Flat"
                                  Click="@(() => OnEditCategory(cat))" Tooltip="Rename" />
                    <RadzenButton Image="delete-x.png" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" Variant="Variant.Flat"
                                  Click="@(() => OnDeleteCategory(cat))" Tooltip="Delete" />
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</RadzenStack>
