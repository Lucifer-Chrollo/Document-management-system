@page "/ManageDocuments"
@page "/ManageDocuments/{CategoryId:int}"
@page "/ManageDocuments/{CategoryId:int}/{ParentId:int}"
@using Radzen.Blazor
@attribute [Authorize]
@inherits Fluxor.Blazor.Web.Components.FluxorComponent
@using DocumentManagementSystem.Models
@using DocumentManagementSystem.Data
@using Microsoft.JSInterop

<PageTitle>Browse Documents - DMS</PageTitle>

@if (isDownloading)
{
    <RadzenStack Style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 9999;" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center">
        <RadzenCard Style="width: 400px; padding: 2rem;">
            <RadzenStack Gap="1rem">
                <RadzenText TextStyle="TextStyle.H6">Downloading Document...</RadzenText>
                <RadzenProgressBar Value="@downloadProgress" Max="100" />
                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween">
                    <RadzenText TextStyle="TextStyle.Caption">@FormatFileSize(bytesDownloaded) / @FormatFileSize(totalBytesToDownload)</RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption">@($"{downloadProgress:0}%")</RadzenText>
                </RadzenStack>
            </RadzenStack>
        </RadzenCard>
    </RadzenStack>
}

<RadzenStack Gap="0.5rem" class="fade-in-up">
    <!-- Header Area -->
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" class="px-2 pt-2">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
            <RadzenIcon Icon="folder_open" Style="font-size: 1.5rem; color: #0071c1;" />
            <RadzenStack Gap="0">
                <RadzenText TextStyle="TextStyle.H5" class="pagetitle-fontsize" Style="margin: 0; font-weight: bold;">Manage Documents</RadzenText>
            </RadzenStack>
        </RadzenStack>
        
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0" class="zero-gap-stack">
            <AuthorizeView>
                <Authorized>
                    <div style="position: relative;" class="me-2">
                        <RadzenButton Icon="tune" Text="Mobile Upload" Click="@ToggleToolsMenu" ButtonStyle="ButtonStyle.Secondary" class="search-button" />
                        @if (isToolsMenuOpen)
                        {
                            <div style="position: absolute; top: 110%; right: 0; width: 320px; z-index: 1000; background: white; border: 1px solid var(--rz-divider); border-radius: 4px; padding: 1rem; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
                                <RadzenStack Gap="1rem">
                                    <DocumentManagementSystem.Components.MfaSetupCard />
                                    <RadzenCard class="rz-shadow-2" Style="cursor: pointer; padding: 1rem; border: 1px solid var(--rz-primary-light);" @onclick="@(() => NavigationManager.NavigateTo("/profile/uploadqr"))">
                                        <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" AlignItems="AlignItems.Center">
                                            <RadzenIcon Icon="qr_code_scanner" Style="font-size: 2rem; color: var(--rz-primary);" />
                                            <RadzenStack Gap="0">
                                                <RadzenText TextStyle="TextStyle.Subtitle2" Style="margin: 0; font-weight: bold;">Mobile Upload</RadzenText>
                                                <RadzenText TextStyle="TextStyle.Caption" class="text-muted" Style="margin: 0; line-height: 1.2;">Generate a secure QR code to upload files from your phone.</RadzenText>
                                            </RadzenStack>
                                        </RadzenStack>
                                    </RadzenCard>
                                </RadzenStack>
                            </div>
                        }
                    </div>
                    <RadzenButton Icon="add" Text="New Document" 
                                  Click="@(() => NavigationManager.NavigateTo("/upload"))"
                                  ButtonStyle="ButtonStyle.Success" class="search-button" />
                </Authorized>
            </AuthorizeView>
        </RadzenStack>
    </RadzenStack>

    <!-- Filter Area (Legacy Based) -->
    <div class="card-body-D px-1 py-1">
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0" Style="flex-wrap: nowrap; overflow-x: auto;" class="zero-gap-stack">
            <RadzenDropDown TValue="int?" Data="@categories" TextProperty="CategoryName" ValueProperty="CategoryId"
                            Placeholder="Category..." @bind-Value="@selectedTopCategoryId" Change="@(args => OnTopCategoryChange(args))" Clearable="true"
                            Style="width: 180px;" />
            
            <RadzenDatePicker TValue="DateTime?[]" SelectionMode="DatePickerSelectionMode.Range" 
                              Placeholder="Date Range..." @bind-Value="@dates" Change="@(args => OnDateRangeChange(args))" Clearable="true"
                              Style="width: 220px;" DateFormat="MMM dd, yyyy" Popup="true" Inline="false" />
            
            <RadzenDropDown TValue="string" Data="@batchLabels" Placeholder="Batch..." 
                            @bind-Value="@selectedBatchLabel" Change="@(args => LoadData())" Clearable="true"
                            Style="width: 150px;" />
            
            <RadzenTextBox Placeholder="Search..." @bind-Value="@searchQuery" 
                           Style="flex: 1; min-width: 150px;" @onkeyup="@((e) => { if(e.Key == "Enter") Search(); })" />
            
            <RadzenButton Icon="search" Click="@(args => Search())" ButtonStyle="ButtonStyle.Primary" class="search-button" Tooltip="Search" />
        </RadzenStack>
    </div>

    <RadzenRow>
        <!-- Document Grid -->
        <RadzenColumn Size="12" SizeMD="12">
            <RadzenCard>
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" class="mb-3">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center">
                        @if (ParentId > 0)
                        {
                            <RadzenButton Icon="arrow_back" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" 
                                           Click="@(args => GoBack())" class="me-2" />
                        }

                    </RadzenStack>
                    @if (selectedDocuments.Any())
                    {
                        <RadzenButton Image="delete-x.png" Text="Delete Selected" ButtonStyle="ButtonStyle.Danger" 
                                       Size="ButtonSize.Small" Click="@(args => DeleteSelected())" />
                    }
                </RadzenStack>

                <RadzenDataGrid Data="@documents" TItem="Document" AllowFiltering="true" AllowSorting="true" 
                                AllowPaging="true" PageSize="10" PagerHorizontalAlign="HorizontalAlign.Left" 
                                ShowPagingSummary="true" SelectionMode="DataGridSelectionMode.Multiple" 
                                @bind-Value="@selectedDocuments" class="rz-shadow-sm"
                                IsLoading="@isLoading">
                    <Columns>
                        <RadzenDataGridColumn TItem="Document" Width="40px" Sortable="false" Filterable="false">
                            <HeaderTemplate>
                                <RadzenCheckBox TabIndex="-1" TriState="false" TValue="bool" 
                                                Value="@(documents.Any() && selectedDocuments.Count == documents.Count())"
                                                Change="@SelectAll" />
                            </HeaderTemplate>
                            <Template Context="doc">
                                <RadzenCheckBox TabIndex="-1" TriState="false" Value="@selectedDocuments.Contains(doc)" 
                                                TValue="bool" Change="@(selected => ToggleSelection(doc, selected))" />
                            </Template>
                        </RadzenDataGridColumn>
                        
                        <RadzenDataGridColumn TItem="Document" Property="DocumentName" Title="Name" Width="250px">
                            <Template Context="doc">
                                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0" class="zero-gap-stack">
                                    <RadzenIcon Icon="@(doc.Status == "Folder" ? "folder" : GetFileIcon(doc.Extension))" 
                                                Style="@(doc.Status == "Folder" ? "font-size: 1.25rem; color: #ffca28;" : "font-size: 1.25rem;")" />
                                    <RadzenStack Gap="0">
                                        @if (doc.Status == "Folder")
                                        {
                                            <RadzenLink Path="@($"/ManageDocuments/{doc.CategoryID}/{doc.DocumentId}")" Text="@doc.DocumentName" 
                                                        Style="font-weight: bold; color: var(--rz-primary);" />
                                        }
                                        else
                                        {
                                            <RadzenLink Path="@($"/documents/{doc.DocumentId}")" Text="@doc.DocumentName" 
                                                        Style="font-weight: 500;" />
                                        }
                                        @if (!string.IsNullOrEmpty(doc.BatchLabel))
                                        {
                                            <RadzenBadge Text="@doc.BatchLabel" BadgeStyle="BadgeStyle.Light" 
                                                         Style="font-size: 0.6rem; padding: 0.2rem 0.4rem; border-radius: 4px; border: 1px solid #ddd;" />
                                        }
                                    </RadzenStack>
                                </RadzenStack>
                            </Template>
                        </RadzenDataGridColumn>

                        <RadzenDataGridColumn TItem="Document" Property="CategoryName" Title="Category" Width="150px" />
                        
                        <RadzenDataGridColumn TItem="Document" Property="FileSize" Title="Size" Width="150px">
                             <Template Context="doc">
                                <RadzenStack Gap="0">
                                    <RadzenText TextStyle="TextStyle.Body2">@FormatFileSize(doc.FileSize)</RadzenText>
                                    @if (doc.CompressedSize.HasValue && doc.CompressedSize < doc.FileSize)
                                    {
                                        <RadzenText TextStyle="TextStyle.Caption" class="text-success">
                                            (@FormatFileSize(doc.CompressedSize.Value) compressed)
                                        </RadzenText>
                                    }
                                </RadzenStack>
                            </Template>
                        </RadzenDataGridColumn>
                        
                        <RadzenDataGridColumn TItem="Document" Property="DepartmentName" Title="Department" Width="150px" />
                        
                        <RadzenDataGridColumn TItem="Document" Property="LocationName" Title="Location Name" Width="150px" />
                        
                        <RadzenDataGridColumn TItem="Document" Property="UploadedDate" Title="Uploaded Date" Width="150px">
                            <Template Context="doc">
                                @doc.UploadedDate.ToString("MMM dd, yyyy")
                            </Template>
                        </RadzenDataGridColumn>
                        
                        <RadzenDataGridColumn TItem="Document" Property="Status" Title="Status" Width="100px">
                            <Template Context="doc">
                                <RadzenBadge BadgeStyle="@(doc.Status == "Active" ? BadgeStyle.Success : BadgeStyle.Warning)" 
                                             Text="@doc.Status" />
                            </Template>
                        </RadzenDataGridColumn>

                        <RadzenDataGridColumn TItem="Document" Context="doc" Filterable="false" Sortable="false" 
                                            TextAlign="TextAlign.Center" Width="120px" Title="Actions">
                            <Template Context="doc">
                                <RadzenButton Icon="visibility" ButtonStyle="ButtonStyle.Info" Size="ButtonSize.ExtraSmall" 
                                               Click="@(() => PreviewDocument(doc))" Disabled="@(doc.Status == "Folder")" Tooltip="Preview" />
                                <RadzenButton Icon="download" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.ExtraSmall" 
                                               Click="@(() => DownloadDocument(doc))" Disabled="@(doc.Status == "Folder")" Tooltip="Download" />
                                <RadzenButton Icon="share" ButtonStyle="ButtonStyle.Info" Size="ButtonSize.ExtraSmall" 
                                              Click="@(() => OnShareDocument(doc))" 
                                              @onclick:stopPropagation="true" 
                                              Title="Share with Group" 
                                              Disabled="@(doc.Status == "Folder")" />
                                <RadzenButton Image="edit-icon.png" ButtonStyle="ButtonStyle.Secondary" Size="ButtonSize.ExtraSmall" />
                                <RadzenButton Image="delete-x.png" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.ExtraSmall" 
                                               Click="@(() => DeleteDocument(doc))" Tooltip="Delete" />
                            </Template>
                        </RadzenDataGridColumn>

                        <RadzenDataGridColumn TItem="Document" Width="60px" Sortable="false" Filterable="false">
                            <Template Context="doc">
                                @if(doc.CommentsList?.Any() == true)
                                {
                                    <RadzenBadge BadgeStyle="BadgeStyle.Info" Text="@doc.CommentsList.Count.ToString()" />
                                }
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>
</RadzenStack>

