@using Radzen
@using Radzen.Blazor
@using DocumentManagementSystem.Models
@using DocumentManagementSystem.Services
@inject IUserGroupService UserGroupService
@inject NotificationService NotificationService
@inject DialogService DialogService

<RadzenStack Gap="0.5rem" Style="padding: 0.5rem; background: #f9f9f9; border: 1px solid #7bc6e6;">
    <!-- Top Section: Group Context and Permissions -->
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem" Wrap="FlexWrap.NoWrap" Style="background: white; padding: 0.5rem; border: 1px solid #ccc;">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
            <RadzenText TextStyle="TextStyle.Body2" class="m-0" Style="min-width: 90px;">
                @(GroupId == 0 ? "New Group Name" : "Selected Group")
            </RadzenText>
            
            @if (GroupId == 0)
            {
                <RadzenTextBox @bind-Value="newGroupName" Style="width: 150px; height: 30px; line-height: 30px;" />
            }
            else
            {
                <RadzenDropDown @bind-Value="GroupId" Data="@groups" TextProperty="GroupName" ValueProperty="GroupId" 
                                Style="width: 150px; height: 30px; line-height: 30px;" Change="@OnGroupChanged" />
            }
        </RadzenStack>

        @if (selectedGroup != null || GroupId == 0)
        {
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem" Style="margin-left: 2rem;">
                <RadzenText TextStyle="TextStyle.Body2" class="m-0" Style="color: #333;">Group Permissions</RadzenText>
                
                <RadzenCheckBox @bind-Value="@canReadBool" Name="canRead" Change="@((bool args) => OnPermissionChanged(1, args))" TValue="bool" />
                <RadzenLabel Text="CanRead" Component="canRead" class="ms-1 rz-text-body2" Style="margin-right: 0.5rem;" />

                <RadzenCheckBox @bind-Value="@canWriteBool" Name="canWrite" Change="@((bool args) => OnPermissionChanged(2, args))" TValue="bool" />
                <RadzenLabel Text="CanWrite" Component="canWrite" class="ms-1 rz-text-body2" Style="margin-right: 0.5rem;" />

                <RadzenCheckBox @bind-Value="@canDeleteBool" Name="canDelete" Change="@((bool args) => OnPermissionChanged(4, args))" TValue="bool" />
                <RadzenLabel Text="CanDelete" Component="canDelete" class="ms-1 rz-text-body2" />
            </RadzenStack>
        }

        @if (GroupId == 0)
        {
            <RadzenButton Text="Create Group" Click="@CreateNewGroup" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" Style="margin-left: auto;" Disabled="@string.IsNullOrWhiteSpace(newGroupName)" />
        }
    </RadzenStack>

    <!-- Middle Section: User Assignment -->
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem" Style="background: white; padding: 0.5rem; border: 1px solid #ccc; border-top: none;">
        <RadzenText TextStyle="TextStyle.Body2" class="m-0" Style="min-width: 140px;">Add a User to this Group</RadzenText>
        
        <RadzenDropDown @bind-Value="selectedUserIdToAdd" Data="@availableUsers" 
                        TextProperty="UserName" ValueProperty="Id" 
                        FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" FilterOperator="StringFilterOperator.Contains" AllowFiltering="true"
                        AllowClear="true" Style="width: 250px;" />

        <RadzenButton Text="Add User" Click="@OnAddUser" Disabled="@(selectedUserIdToAdd == 0)" 
                      ButtonStyle="ButtonStyle.Light" Style="border: 1px solid #aaa; border-radius: 0; padding: 0 15px; color: #333; margin-left:1rem;" />
    </RadzenStack>

    <!-- Bottom Section: Current Members Grid -->
    <RadzenDataGrid Data="@(GroupId == 0 ? pendingMembers : members)" TItem="UserGroupMember" IsLoading="@isLoadingMembers"
                    Style="border: 1px solid #ccc; border-radius: 0; min-height: 150px;"
                    AllowSorting="true">
        <Columns>
            <RadzenDataGridColumn TItem="UserGroupMember" Property="UserName" Title="User Name" />
            <RadzenDataGridColumn TItem="UserGroupMember" Property="DepartmentName" Title="Department" />
            <RadzenDataGridColumn TItem="UserGroupMember" Title="Action" Width="80px" TextAlign="TextAlign.Center">
                <Template Context="member">
                    <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat" Size="ButtonSize.Medium" 
                                    Click="@(() => OnRemoveUser(member))" Style="color: #d32f2f; background: transparent; font-weight: bold; font-size: 1.2rem;" />
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</RadzenStack>
