@using Radzen
@using Radzen.Blazor
@using DocumentManagementSystem.Models
@using DocumentManagementSystem.Services
@inject IUserGroupService UserGroupService
@inject NotificationService NotificationService
@inject DialogService DialogService

<RadzenStack Gap="1rem" Style="padding: 1rem;">
    <!-- Top Section: Group Context and Permissions -->
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1.5rem" Wrap="FlexWrap.Wrap">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
            <RadzenText TextStyle="TextStyle.Body1" class="m-0" Style="font-weight: bold; min-width: 100px;">Selected Group</RadzenText>
            <RadzenDropDown @bind-Value="GroupId" Data="@groups" TextProperty="GroupName" ValueProperty="GroupId" 
                            Style="width: 200px;" Change="@OnGroupChanged" />
        </RadzenStack>

        @if (selectedGroup != null)
        {
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
                <RadzenText TextStyle="TextStyle.Body1" class="m-0" Style="color: #666;">Group Permissions</RadzenText>
                
                <RadzenCheckBox @bind-Value="@canReadBool" Name="canRead" Change="@((bool args) => OnPermissionChanged("Read", args))" TValue="bool" />
                <RadzenLabel Text="CanRead" Component="canRead" class="ms-1 rz-text-body2" />

                <RadzenCheckBox @bind-Value="@canWriteBool" Name="canWrite" Change="@((bool args) => OnPermissionChanged("Write", args))" TValue="bool" />
                <RadzenLabel Text="CanWrite" Component="canWrite" class="ms-1 rz-text-body2" />

                <RadzenCheckBox @bind-Value="@canDeleteBool" Name="canDelete" Change="@((bool args) => OnPermissionChanged("Delete", args))" TValue="bool" />
                <RadzenLabel Text="CanDelete" Component="canDelete" class="ms-1 rz-text-body2" />
            </RadzenStack>
        }
    </RadzenStack>

    <hr style="border-top: 1px solid #e0e0e0; margin: 0.5rem 0;" />

    <!-- Middle Section: User Assignment -->
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
        <RadzenText TextStyle="TextStyle.Body2" class="m-0" Style="min-width: 130px;">Add a User to this Group</RadzenText>
        
        <RadzenDropDown @bind-Value="selectedUserIdToAdd" Data="@availableUsers" 
                        TextProperty="UserName" ValueProperty="Id" 
                        FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" FilterOperator="StringFilterOperator.Contains" AllowFiltering="true"
                        AllowClear="true" Placeholder="Select a User..." Style="flex: 1; max-width: 300px;" />

        <RadzenButton Text="Add User" Click="@OnAddUser" Disabled="@(selectedUserIdToAdd == 0)" 
                      ButtonStyle="ButtonStyle.Light" Style="border: 1px solid #aaa; border-radius: 0; padding: 0 15px; color: #333;" />
    </RadzenStack>

    <!-- Bottom Section: Current Members Grid -->
    <RadzenDataGrid Data="@members" TItem="UserGroupMember" IsLoading="@isLoadingMembers"
                    Style="border: 1px solid #ccc; border-radius: 0; min-height: 250px;"
                    AllowSorting="true">
        <Columns>
            <RadzenDataGridColumn TItem="UserGroupMember" Property="FullName" Title="User Name" />
            <RadzenDataGridColumn TItem="UserGroupMember" Property="Email" Title="Email" />
            <RadzenDataGridColumn TItem="UserGroupMember" Title="Action" Width="100px" TextAlign="TextAlign.Center">
                <Template Context="member">
                    <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat" Size="ButtonSize.Small" 
                                  Click="@(() => OnRemoveUser(member))" Style="color: #d32f2f; background: transparent; font-weight: bold;" Tooltip="Remove User" />
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</RadzenStack>

@code {
    [Parameter] public int GroupId { get; set; }
    [Parameter] public int currentUserId { get; set; }

    private IEnumerable<UserGroup> groups = Enumerable.Empty<UserGroup>();
    private UserGroup? selectedGroup;
    private IEnumerable<UserGroupMember> members = Enumerable.Empty<UserGroupMember>();
    private IEnumerable<ApplicationUser> availableUsers = Enumerable.Empty<ApplicationUser>();
    
    private int selectedUserIdToAdd;
    private bool isLoadingMembers = true;

    // UI Bindings for permissions (integers mapped to booleans)
    private bool canReadBool;
    private bool canWriteBool;
    private bool canDeleteBool;

    protected override async Task OnInitializedAsync()
    {
        await LoadBaseData();
        await LoadGroupDetails();
    }

    private async Task LoadBaseData()
    {
        groups = await UserGroupService.GetAllGroupsAsync();
        availableUsers = await UserGroupService.SearchUsersAsync(""); // load all users initially
    }

    private async Task LoadGroupDetails()
    {
        isLoadingMembers = true;
        
        selectedGroup = groups.FirstOrDefault(g => g.GroupId == GroupId);
        if (selectedGroup != null)
        {
            canReadBool = selectedGroup.CanRead == 1;
            canWriteBool = selectedGroup.CanWrite == 1;
            canDeleteBool = selectedGroup.CanDelete == 1;
        }

        members = await UserGroupService.GetGroupMembersDetailedAsync(GroupId);
        selectedUserIdToAdd = 0; // reset dropdown
        
        isLoadingMembers = false;
        StateHasChanged();
    }

    private async Task OnGroupChanged(object value)
    {
        if (value is int newGroupId)
        {
            GroupId = newGroupId;
            await LoadGroupDetails();
        }
    }

    private async Task OnPermissionChanged(string type, bool isChecked)
    {
        if (selectedGroup == null) return;

        // Update local object
        if (type == "Read") selectedGroup.CanRead = isChecked ? 1 : 0;
        else if (type == "Write") selectedGroup.CanWrite = isChecked ? 1 : 0;
        else if (type == "Delete") selectedGroup.CanDelete = isChecked ? 1 : 0;

        // Auto-save changes
        var response = await UserGroupService.UpdateGroupAsync(selectedGroup, currentUserId);
        
        if (response.Result)
        {
            NotificationService.Notify(NotificationSeverity.Success, "Saved", $"{type} permission updated.");
        }
        else
        {
            // Revert on failure
            if (type == "Read") canReadBool = !isChecked;
            else if (type == "Write") canWriteBool = !isChecked;
            else if (type == "Delete") canDeleteBool = !isChecked;
            NotificationService.Notify(NotificationSeverity.Error, "Error", response.Message);
        }
    }

    private async Task OnAddUser()
    {
        if (selectedUserIdToAdd <= 0 || selectedGroup == null) return;

        // Don't add if already a member
        if (members.Any(m => m.UserId == selectedUserIdToAdd))
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Info", "User is already in this group.");
            return;
        }

        var response = await UserGroupService.AddUserToGroupAsync(selectedUserIdToAdd, GroupId);
        
        if (response.Result)
        {
            NotificationService.Notify(NotificationSeverity.Success, "Added", "User successfully added to group.");
            await LoadGroupDetails(); // refresh member list
        }
        else
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", response.Message);
        }
    }

    private async Task OnRemoveUser(UserGroupMember member)
    {
        var response = await UserGroupService.RemoveUserFromGroupAsync(member.UserId, GroupId);
        
        if (response.Result)
        {
            NotificationService.Notify(NotificationSeverity.Success, "Removed", "User removed from group.");
            await LoadGroupDetails(); // refresh member list
        }
        else
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", response.Message);
        }
    }
}
