@page "/groups"
@using Radzen
@using Radzen.Blazor
@using DocumentManagementSystem.Models
@using DocumentManagementSystem.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject IUserGroupService UserGroupService
@inject NotificationService NotificationService
@inject DialogService DialogService
@inject AuthenticationStateProvider AuthStateProvider
@* @attribute [Authorize(Roles = "Admin")] - Removed so any user can access groups *@

<RadzenStack Gap="1rem" Style="padding: 2rem;">
    <!-- Header Area -->
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
        <RadzenIcon Icon="group" Style="font-size: 1.5rem;" />
        <RadzenText TextStyle="TextStyle.H5" class="m-0" Style="color: #2b5797;">Manage User Groups</RadzenText>
    </RadzenStack>

    <hr style="border-top: 2px solid #e0e0e0; margin: 0;" />

    <!-- Toolbar Area -->
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem" class="mt-2 mb-3">
        <RadzenButton class="rz-border-radius-1" Icon="add" Text="Add New Group" ButtonStyle="ButtonStyle.Light" 
                      Click="@OnAddGroup" Style="font-weight: bold; color: #0078d4; border: 1px solid #0078d4; padding: 0 20px;" />
    </RadzenStack>

    <!-- Data Grid -->
    <RadzenDataGrid Data="@groups" TItem="UserGroup" IsLoading="@isLoading"
                    Style="border: 1px solid #ccc; border-radius: 0;"
                    AllowColumnResize="true" AllowSorting="true">
        <Columns>
            <RadzenDataGridColumn TItem="UserGroup" Property="GroupId" Title="Index" Width="80px" />
            <RadzenDataGridColumn TItem="UserGroup" Property="GroupName" Title="Group Name" />
            <RadzenDataGridColumn TItem="UserGroup" Title="Allowed Permissions">
                <Template Context="group">
                    @{
                        var perms = new List<string>();
                        if ((group.DefaultRights & 1) == 1) perms.Add("Read");
                        if ((group.DefaultRights & 2) == 2) perms.Add("Write");
                        if ((group.DefaultRights & 4) == 4) perms.Add("Delete");
                        
                        var displayContent = perms.Count == 3 ? "Full Control" : (perms.Count == 0 ? "None" : string.Join(", ", perms));
                        <RadzenText TextStyle="TextStyle.Body2" class="m-0">@displayContent</RadzenText>
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="UserGroup" Property="MemberCount" Title="Total Users" Width="120px" TextAlign="TextAlign.Center" />
            <RadzenDataGridColumn TItem="UserGroup" Title="Action" Width="120px" TextAlign="TextAlign.Center" Sortable="false">
                <Template Context="group">
                    <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat" Size="ButtonSize.Small" 
                                  Click="@(() => OnEditGroup(group))" Style="color: #0078d4; background: transparent;" Tooltip="Edit Group Users & Permissions" />
                    <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat" Size="ButtonSize.Small" 
                                  Click="@(() => OnDeleteGroup(group))" Style="color: #d32f2f; background: transparent; font-weight: bold;" Tooltip="Delete Group" />
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</RadzenStack>
