@page "/documents/{Id:int}"
@inject IDocumentService DocumentService
@inject NavigationManager NavigationManager
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject IJSRuntime JSRuntime
@implements IDisposable
@using DocumentManagementSystem.Models
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ICommentService CommentService
@inject DocumentManagementSystem.Data.Repositories.IDocumentRepository DocumentRepository
@using System
@using System.Net

<PageTitle>@(document?.DocumentName ?? "Document") - DMS</PageTitle>

@if (isDownloading)
{
    <div class="download-overlay" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 9999; display: flex; align-items: center; justify-content: center;">
        <RadzenCard Style="width: 400px; padding: 2rem;">
            <RadzenStack Gap="1rem">
                <RadzenText TextStyle="TextStyle.H6">Downloading Document...</RadzenText>
                <RadzenProgressBar Value="@downloadProgress" Max="100" />
                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween">
                    <RadzenText TextStyle="TextStyle.Caption">@FormatFileSize(bytesDownloaded) / @FormatFileSize(totalBytesToDownload)</RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption">@($"{downloadProgress:0}%")</RadzenText>
                </RadzenStack>
            </RadzenStack>
        </RadzenCard>
    </div>
}

@if (document == null)
{
    <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Style="min-height: 400px;">
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
        <RadzenText>Loading document...</RadzenText>
    </RadzenStack>
}
else
{
    @if (isUnlocked)
    {
<RadzenStack Gap="0.5rem" class="p-2 fade-in-up">
    <!-- Header Area -->
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
        <RadzenButton Icon="arrow_back" ButtonStyle="ButtonStyle.Light" Click="@GoBack" class="search-button" />
        <div class="document-icon @GetIconClass(document.Extension)" 
             style="width: 36px; height: 36px; font-size: 1.25rem; display: flex; align-items: center; justify-content: center; color: #0071c1;">
            <RadzenIcon Icon="@GetFileIcon(document.Extension)" />
        </div>
        <RadzenStack Gap="0" Style="flex: 1;">
            <RadzenText TextStyle="TextStyle.H5" class="pagetitle-fontsize" Style="margin: 0; font-weight: bold;">@document.DocumentName</RadzenText>
            <RadzenText TextStyle="TextStyle.Caption" class="text-muted">@document.Path</RadzenText>
        </RadzenStack>
    </RadzenStack>

    <!-- Action Area (Legacy Based) -->
    <div class="card-body-D px-1 py-1">
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0" class="zero-gap-stack">
            <RadzenButton Text="Download" Icon="download" Click="@DownloadDocument" class="search-button" />
            <RadzenButton Text="Share" Icon="share" Click="@OnShareDocument" class="search-button" />
            
            @if (canWrite)
            {
                <RadzenButton Text="New Version" Icon="upload_file" Click="@UploadNewVersion" class="search-button" />
                <RadzenButton Text="Edit" Image="edit-icon.png" Click="@ShowEditDialog" class="search-button" />
            }
            
            @if (canDelete)
            {
                <RadzenButton Image="delete-x.png" Click="@DeleteDocument" ButtonStyle="ButtonStyle.Danger" class="search-button" />
            }
        </RadzenStack>
    </div>

            <RadzenRow Gap="1.5rem">
                <!-- Document Details -->
                <RadzenColumn Size="12" SizeLG="8">
                    <RadzenStack Gap="1.5rem">
                        
                        @if (IsImage(document.Extension))
                        {
                            <!-- Image Preview -->
                            <RadzenCard>
                                <RadzenText TextStyle="TextStyle.H6" class="mb-3">
                                    <RadzenIcon Icon="visibility" /> Preview
                                </RadzenText>
                                <div style="text-align: center; background: #f8f9fa; padding: 1rem; border-radius: 8px;">
                                    @{
                                        var previewUrl = $"/api/files/preview/{document.DocumentId}";
                                        if (!string.IsNullOrEmpty(document.Password))
                                        {
                                            previewUrl += $"?pwd={Uri.EscapeDataString(document.Password)}";
                                        }
                                    }
                                    <img src="@previewUrl" 
                                         style="max-width: 100%; max-height: 600px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); border-radius: 4px;" 
                                         alt="Document Preview" />
                                </div>
                            </RadzenCard>
                        }

                        <!-- Comments Details -->
                        <RadzenCard>
                            <RadzenText TextStyle="TextStyle.H6" class="mb-3">
                                <RadzenIcon Icon="comment" /> Comments
                            </RadzenText>
                            
                            @if (document.CommentsList?.Any() == true)
                            {
                                <RadzenDataGrid Data="@document.CommentsList" TItem="Comments" Density="Density.Compact" Style="margin-bottom: 1rem;">
                                    <Columns>
                                        <RadzenDataGridColumn TItem="Comments" Property="CommentByName" Title="User" Width="150px">
                                            <Template Context="c">
                                                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                                                    <RadzenIcon Icon="person" Style="font-size: 1.2rem; color: #666;" />
                                                    <RadzenText TextStyle="TextStyle.Body2">@(string.IsNullOrEmpty(c.CommentByName) ? $"User {c.CommentBy}" : c.CommentByName)</RadzenText>
                                                </RadzenStack>
                                            </Template>
                                        </RadzenDataGridColumn>
                                        <RadzenDataGridColumn TItem="Comments" Property="Comment" Title="Comment" />
                                        <RadzenDataGridColumn TItem="Comments" Property="CommentDate" Title="Date" Width="150px" FormatString="{0:g}" />
                                    </Columns>
                                </RadzenDataGrid>
                            }
                            else
                            {
                                <RadzenText class="text-muted" Style="margin-bottom: 1rem;">No comments yet.</RadzenText>
                            }

                            <!-- Add Comment Form -->
                            <RadzenStack Gap="0.5rem">
                                <RadzenTextArea @bind-Value="@newCommentText" Placeholder="Add a comment..." Style="width: 100%; min-height: 80px;" disabled="@isPostingComment" />
                                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End">
                                    <RadzenButton Text="Post Comment" Icon="send" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" 
                                                  Click="@PostComment" IsBusy="@isPostingComment" Disabled="@(string.IsNullOrWhiteSpace(newCommentText))" />
                                </RadzenStack>
                            </RadzenStack>
                        </RadzenCard>

                        <!-- User Rights -->
                        <RadzenCard>
                            <RadzenText TextStyle="TextStyle.H6" class="mb-3">
                                <RadzenIcon Icon="lock_person" /> User Rights
                            </RadzenText>
                             @if (document.UserDocumentRightsList?.Any() == true)
                            {
                                <RadzenDataGrid Data="@document.UserDocumentRightsList" TItem="UserDocumentRights" Density="Density.Compact">
                                    <Columns>
                                        <RadzenDataGridColumn TItem="UserDocumentRights" Property="UserName" Title="User" />
                                        <RadzenDataGridColumn TItem="UserDocumentRights" Property="RightsName" Title="Permissions" />
                                    </Columns>
                                </RadzenDataGrid>
                            }
                            else
                            {
                                <RadzenText class="text-muted">No specific user rights assigned.</RadzenText>
                            }
                        </RadzenCard>

                        <!-- Version History -->
                        <RadzenCard>
                            <RadzenText TextStyle="TextStyle.H6" class="mb-3">
                                <RadzenIcon Icon="history" /> Version History
                            </RadzenText>
                            @if (history.Any())
                            {
                                <RadzenDataGrid Data="@history" TItem="DocumentVersion" Density="Density.Compact" PageSize="5" AllowPaging="true">
                                    <Columns>
                                        <RadzenDataGridColumn TItem="DocumentVersion" Property="VersionNumber" Title="Ver" Width="60px" />
                                        <RadzenDataGridColumn TItem="DocumentVersion" Property="CreatedDate" Title="Date" FormatString="{0:g}" />
                                        <RadzenDataGridColumn TItem="DocumentVersion" Title="Size" Width="80px">
                                            <Template Context="v">@FormatFileSize(v.FileSize)</Template>
                                        </RadzenDataGridColumn>
                                        <RadzenDataGridColumn TItem="DocumentVersion" Context="v" Filterable="false" Sortable="false" TextAlign="TextAlign.Center" Width="130px">
                                            <Template Context="v">
                                                <RadzenButton Icon="visibility" Size="ButtonSize.ExtraSmall" ButtonStyle="ButtonStyle.Info" 
                                                              Click="@(() => PreviewVersion(v))" Tooltip="Preview" />
                                                <RadzenButton Icon="download" Size="ButtonSize.ExtraSmall" ButtonStyle="ButtonStyle.Light" 
                                                              Click="@(() => DownloadVersion(v))" Tooltip="Download" />
                                                <RadzenButton Icon="restore" Size="ButtonSize.ExtraSmall" ButtonStyle="ButtonStyle.Warning" 
                                                              Click="@(() => RestoreVersion(v))" Tooltip="Restore" />
                                            </Template>
                                        </RadzenDataGridColumn>
                                    </Columns>
                                </RadzenDataGrid>
                            }
                            else
                            {
                                <RadzenText class="text-muted">No previous versions.</RadzenText>
                            }
                        </RadzenCard>

                    </RadzenStack>
                </RadzenColumn>

                <!-- Sidebar -->
                <RadzenColumn Size="12" SizeLG="4">
                    <RadzenStack Gap="1.5rem">
                        <!-- Properties -->
                        <RadzenCard>
                            <RadzenText TextStyle="TextStyle.H6" class="mb-3">
                                <RadzenIcon Icon="list" /> Properties
                            </RadzenText>
                            <RadzenStack Gap="0.75rem">
                                @PropertyRow("Extension", document.Extension)
                                @PropertyRow("Size", FormatFileSize(document.FileSize))
                                @if (document.CompressedSize.HasValue && document.CompressedSize < document.FileSize)
                                {
                                    @PropertyRow("Compressed", FormatFileSize(document.CompressedSize.Value))
                                }
                                @PropertyRow("Category", document.CategoryName)
                                @PropertyRow("Department", document.DepartmentName)
                                @PropertyRow("Location", document.LocationName)
                                @PropertyRow("Status", document.Status)
                                @if (!string.IsNullOrEmpty(document.Password))
                                {
                                    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween">
                                        <RadzenText TextStyle="TextStyle.Body2" class="text-muted">Protected</RadzenText>
                                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.25rem">
                                            <RadzenIcon Icon="lock" Style="font-size: 1rem; color: #fbc02d;" />
                                            <RadzenText TextStyle="TextStyle.Body2" Style="font-weight: 500;">Yes</RadzenText>
                                        </RadzenStack>
                                    </RadzenStack>
                                    @if (isAdmin)
                                    {
                                        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
                                            <RadzenText TextStyle="TextStyle.Body2" class="text-muted">Password</RadzenText>
                                            @if (showDocPassword)
                                            {
                                                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.25rem">
                                                    <RadzenText TextStyle="TextStyle.Body2" Style="font-weight: 500; font-family: monospace; background: #f1f3f5; padding: 2px 8px; border-radius: 4px;">@document.Password</RadzenText>
                                                    <RadzenButton Icon="visibility_off" Size="ButtonSize.ExtraSmall" ButtonStyle="ButtonStyle.Light" 
                                                                  Click="@(() => showDocPassword = false)" Tooltip="Hide password" />
                                                </RadzenStack>
                                            }
                                            else
                                            {
                                                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.25rem">
                                                    <RadzenText TextStyle="TextStyle.Body2" Style="font-weight: 500;">â€¢â€¢â€¢â€¢â€¢â€¢</RadzenText>
                                                    <RadzenButton Icon="visibility" Size="ButtonSize.ExtraSmall" ButtonStyle="ButtonStyle.Light" 
                                                                  Click="@(() => showDocPassword = true)" Tooltip="Reveal password (Admin)" />
                                                </RadzenStack>
                                            }
                                        </RadzenStack>
                                    }
                                }
                            </RadzenStack>
                        </RadzenCard>

                        <!-- Timestamps -->
                        <RadzenCard>
                            <RadzenText TextStyle="TextStyle.H6" class="mb-3">
                                <RadzenIcon Icon="schedule" /> Timestamps
                            </RadzenText>
                            <RadzenStack Gap="0.75rem">
                                @PropertyRow("Uploaded", document.UploadedDate.ToString("MMM dd, yyyy HH:mm"))
                                @PropertyRow("Updated", document.UpdatedDate.ToString("MMM dd, yyyy HH:mm"))
                                @PropertyRow("By User", document.UserName)
                                @PropertyRow("Updated By", document.UpdatedByName)
                            </RadzenStack>
                        </RadzenCard>
                    </RadzenStack>
                </RadzenColumn>
            </RadzenRow>
        </RadzenStack>
    }
    else
    {
        <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Style="min-height: 400px;">
            <RadzenCard Style="width: 400px; text-align: center; padding: 2rem;">
                <RadzenIcon Icon="lock" Style="font-size: 3rem; color: #fbc02d; margin-bottom: 1rem;" />
                <RadzenText TextStyle="TextStyle.H5" class="mb-3">Protected Document</RadzenText>
                <RadzenText TextStyle="TextStyle.Body1" class="mb-4">This document requires a password to view its contents and metadata.</RadzenText>
                
                <RadzenPassword @bind-Value="enteredPassword" Style="width: 100%; display: block; margin-bottom: 1rem;" 
                                Placeholder="Enter password..." @onkeyup="@(e => { if (e.Key == "Enter") UnlockDocument(); })" />
                
                @if (passwordError)
                {
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: #d32f2f; display: block; margin-bottom: 1rem;">
                        Invalid password. Please try again.
                    </RadzenText>
                }

                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.Center" Gap="1rem">
                    <RadzenButton Text="Go Back" ButtonStyle="ButtonStyle.Light" Click="@GoBack" />
                    <RadzenButton Text="Unlock" ButtonStyle="ButtonStyle.Primary" Click="@UnlockDocument" Disabled="@string.IsNullOrWhiteSpace(enteredPassword)" />
                </RadzenStack>
            </RadzenCard>
        </RadzenStack>
    }
}

@code {
    private RenderFragment PropertyRow(string label, string? value) => __builder =>
    {
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween">
            <RadzenText TextStyle="TextStyle.Body2" class="text-muted">@label</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" Style="font-weight: 500;">@(value ?? "N/A")</RadzenText>
        </RadzenStack>
    };
}
