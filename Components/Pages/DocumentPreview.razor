@using DocumentManagementSystem.Models
@inject DialogService DialogService

<div style="height: 100%; width: 100%; min-height: 500px;">
    <iframe src="/api/files/preview/@DocumentId" 
            style="width: 100%; height: 100%; min-height: 600px; border: none;">
    </iframe>
</div>

<RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem" class="mt-3">
    <RadzenButton Text="Close" Click="() => DialogService.Close()" ButtonStyle="ButtonStyle.Light" />
</RadzenStack>

@code {
    [Parameter]
    public int DocumentId { get; set; }
}
