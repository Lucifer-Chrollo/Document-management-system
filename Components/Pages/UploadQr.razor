@page "/profile/upload-qr"
@using DocumentManagementSystem.Models
@using DocumentManagementSystem.Services
@using Microsoft.AspNetCore.Identity
@using System.Security.Claims
@inject IUploadSessionService UploadSessionService
@inject IDocumentService DocumentService
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation
@inject NotificationService NotificationService
@inject AuthenticationStateProvider AuthStateProvider
@inject IHttpContextAccessor HttpContextAccessor

<PageTitle>Mobile Upload QR - DMS</PageTitle>

<RadzenStack Gap="1.5rem" class="p-4" Style="max-width: 800px;">
    <!-- Header -->
    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
        <RadzenIcon Icon="qr_code_2" Style="font-size: 2rem; color: var(--rz-primary);" />
        <RadzenText TextStyle="TextStyle.H4" Style="margin: 0;">Mobile Upload</RadzenText>
    </RadzenStack>

    <RadzenText class="text-muted">
        Generate a secure QR code to upload files directly from your phone without logging in.
    </RadzenText>

    @if (!showQrCode)
    {
        <!-- Session Creation Form -->
        <RadzenCard>
            <RadzenStack Gap="1rem">
                <RadzenText TextStyle="TextStyle.H6">Create Upload Session</RadzenText>
                
                <RadzenRow Gap="1rem">
                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenStack Gap="0.25rem">
                            <RadzenLabel Text="Session Duration" />
                            <RadzenDropDown @bind-Value="@expiryMinutes" Data="@expiryOptions" 
                                            TextProperty="Text" ValueProperty="Value" Style="width: 100%;" />
                        </RadzenStack>
                    </RadzenColumn>
                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenStack Gap="0.25rem">
                            <RadzenLabel Text="Max Files" />
                            <RadzenNumeric @bind-Value="@maxFiles" Min="1" Max="50" Style="width: 100%;" />
                        </RadzenStack>
                    </RadzenColumn>
                </RadzenRow>

                <RadzenRow Gap="1rem">
                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenStack Gap="0.25rem">
                            <RadzenLabel Text="Default Category (Optional)" />
                            <RadzenDropDown @bind-Value="@selectedCategoryId" Data="@categories" 
                                            TextProperty="CategoryName" ValueProperty="CategoryId" 
                                            Placeholder="Select category..." AllowClear="true" Style="width: 100%;" />
                        </RadzenStack>
                    </RadzenColumn>
                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenStack Gap="0.25rem">
                            <RadzenLabel Text="Session Label (Optional)" />
                            <RadzenTextBox @bind-Value="@sessionLabel" Placeholder="e.g., Meeting Documents" Style="width: 100%;" />
                        </RadzenStack>
                    </RadzenColumn>
                </RadzenRow>

                <RadzenButton Text="Generate QR Code" Icon="qr_code" ButtonStyle="ButtonStyle.Primary" 
                              Click="@GenerateSession" IsBusy="@isGenerating" />
            </RadzenStack>
        </RadzenCard>
    }
    else
    {
        <!-- QR Code Display -->
        <RadzenCard>
            <RadzenStack Gap="1rem" AlignItems="AlignItems.Center">
                <RadzenAlert AlertStyle="AlertStyle.Success" Shade="Shade.Lighter" Style="width: 100%;">
                    <strong>Session Created!</strong> Scan this QR code with your phone's camera.
                </RadzenAlert>

                <!-- QR Code -->
                <RadzenStack AlignItems="AlignItems.Center" class="py-3">
                    <img src="@qrCodeUrl" 
                         alt="Upload QR Code" style="border: 1px solid #ddd; padding: 10px; border-radius: 8px; width: 250px; height: 250px;" />
                </RadzenStack>

                <!-- PIN Display -->
                <RadzenCard Style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 1.5rem;">
                    <RadzenStack AlignItems="AlignItems.Center" Gap="0.5rem">
                        <RadzenText Style="font-size: 0.9rem; opacity: 0.9;">Your PIN Code</RadzenText>
                        <RadzenText Style="font-size: 2.5rem; font-weight: bold; letter-spacing: 0.5rem; font-family: monospace;">@generatedPin</RadzenText>
                        <RadzenText Style="font-size: 0.8rem; opacity: 0.8;">You'll need this to unlock the upload page</RadzenText>
                    </RadzenStack>
                </RadzenCard>

                <!-- Session Info -->
                <RadzenStack Orientation="Orientation.Horizontal" Gap="2rem" JustifyContent="JustifyContent.Center" class="mt-2">
                    <RadzenStack AlignItems="AlignItems.Center">
                        <RadzenIcon Icon="timer" />
                        <RadzenText>Expires in @expiryMinutes min</RadzenText>
                    </RadzenStack>
                    <RadzenStack AlignItems="AlignItems.Center">
                        <RadzenIcon Icon="upload_file" />
                        <RadzenText>Max @maxFiles files</RadzenText>
                    </RadzenStack>
                    <RadzenStack AlignItems="AlignItems.Center">
                        <RadzenIcon Icon="pin" />
                        <RadzenText>3 PIN attempts</RadzenText>
                    </RadzenStack>
                </RadzenStack>

                <RadzenAlert AlertStyle="AlertStyle.Warning" Shade="Shade.Lighter" Style="width: 100%;" class="mt-3">
                    <strong>Important:</strong> The PIN is shown only once. If you lose it, generate a new session.
                </RadzenAlert>

                <RadzenButton Text="Generate New Session" Icon="refresh" ButtonStyle="ButtonStyle.Light" 
                              Click="@ResetForm" />
            </RadzenStack>
        </RadzenCard>
    }

    <!-- Active Sessions -->
    <RadzenCard>
        <RadzenStack Gap="1rem">
            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
                <RadzenText TextStyle="TextStyle.H6">Your Active Sessions</RadzenText>
                <RadzenButton Text="Refresh" Icon="refresh" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="@LoadSessions" />
            </RadzenStack>

            @if (sessions.Any())
            {
                <RadzenDataGrid Data="@sessions" TItem="UploadSession" Density="Density.Compact">
                    <Columns>
                        <RadzenDataGridColumn TItem="UploadSession" Property="Label" Title="Label" Width="150px">
                            <Template Context="s">@(s.Label ?? "Unlabeled")</Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="UploadSession" Title="Status" Width="100px">
                            <Template Context="s">
                                @if (!s.IsActive)
                                {
                                    <RadzenBadge BadgeStyle="BadgeStyle.Secondary" Text="Revoked" />
                                }
                                else if (DateTime.UtcNow >= s.ExpiresAt)
                                {
                                    <RadzenBadge BadgeStyle="BadgeStyle.Danger" Text="Expired" />
                                }
                                else if (s.FilesUploaded >= s.MaxFiles)
                                {
                                    <RadzenBadge BadgeStyle="BadgeStyle.Warning" Text="Full" />
                                }
                                else
                                {
                                    <RadzenBadge BadgeStyle="BadgeStyle.Success" Text="Active" />
                                }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="UploadSession" Title="Files" Width="80px" TextAlign="TextAlign.Center">
                            <Template Context="s">@s.FilesUploaded / @s.MaxFiles</Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="UploadSession" Title="Expires" Width="120px">
                            <Template Context="s">
                                @if (s.RemainingMinutes > 0 && s.IsActive)
                                {
                                    <span>@s.RemainingMinutes min left</span>
                                }
                                else
                                {
                                    <span class="text-muted">@s.ExpiresAt.ToString("MMM dd HH:mm")</span>
                                }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="UploadSession" Title="Actions" Width="100px" TextAlign="TextAlign.Center">
                            <Template Context="s">
                                @if (s.IsValid)
                                {
                                    <RadzenButton Icon="block" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" 
                                                  Variant="Variant.Text" Click="@(() => RevokeSession(s.SessionId))" title="Revoke" />
                                }
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            }
            else
            {
                <RadzenText class="text-muted text-center">No upload sessions found.</RadzenText>
            }
        </RadzenStack>
    </RadzenCard>
</RadzenStack>

@code {
    private bool showQrCode;
    private bool isGenerating;
    private int expiryMinutes = 15;
    private int maxFiles = 10;
    private int? selectedCategoryId;
    private string sessionLabel = "";
    private string uploadUrl = "";
    private string qrCodeUrl = "";
    private string generatedPin = "";
    private int currentUserId;
    
    private IEnumerable<UploadSession> sessions = Enumerable.Empty<UploadSession>();
    private IEnumerable<Category> categories = Enumerable.Empty<Category>();

    private readonly List<object> expiryOptions = new()
    {
        new { Text = "5 minutes", Value = 5 },
        new { Text = "15 minutes", Value = 15 },
        new { Text = "30 minutes", Value = 30 },
        new { Text = "1 hour", Value = 60 },
        new { Text = "2 hours", Value = 120 }
    };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userIdClaim = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (int.TryParse(userIdClaim, out var uid))
        {
            currentUserId = uid;
        }

        await LoadCategories();
        await LoadSessions();
    }

    private async Task LoadCategories()
    {
        categories = await DocumentService.GetCategoriesAsync();
    }

    private async Task LoadSessions()
    {
        sessions = await UploadSessionService.GetUserSessionsAsync(currentUserId);
        StateHasChanged();
    }

    private async Task GenerateSession()
    {
        isGenerating = true;
        StateHasChanged();

        try
        {
            var ipAddress = HttpContextAccessor.HttpContext?.Connection.RemoteIpAddress?.ToString();
            var (session, pin) = await UploadSessionService.CreateSessionAsync(
                currentUserId, 
                expiryMinutes, 
                maxFiles, 
                selectedCategoryId, 
                string.IsNullOrWhiteSpace(sessionLabel) ? null : sessionLabel,
                ipAddress
            );

            generatedPin = pin;
            
            // Get local IP address for mobile access
            var baseUri = Navigation.BaseUri;
            try 
            {
                var hostName = System.Net.Dns.GetHostName();
                var ips = await System.Net.Dns.GetHostAddressesAsync(hostName);
                var lanIp = ips.FirstOrDefault(ip => ip.AddressFamily == System.Net.Sockets.AddressFamily.InterNetwork 
                    && !System.Net.IPAddress.IsLoopback(ip));
                
                if (lanIp != null)
                {
                    baseUri = $"http://{lanIp}:5197/";
                }
            }
            catch 
            {
                // Fallback to BaseUri if IP detection fails
            }

            uploadUrl = $"{baseUri}m/upload/{session.Token}";
            qrCodeUrl = $"https://api.qrserver.com/v1/create-qr-code/?size=250x250&data={Uri.EscapeDataString(uploadUrl)}";
            showQrCode = true;
            
            await LoadSessions();
            NotificationService.Notify(NotificationSeverity.Success, "Success", "Upload session created!");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", "Failed to create session.");
        }
        finally
        {
            isGenerating = false;
            StateHasChanged();
        }
    }

    private async Task RevokeSession(int sessionId)
    {
        var result = await UploadSessionService.RevokeSessionAsync(sessionId, currentUserId);
        if (result)
        {
            NotificationService.Notify(NotificationSeverity.Info, "Revoked", "Session has been revoked.");
            await LoadSessions();
        }
    }

    private void ResetForm()
    {
        showQrCode = false;
        generatedPin = "";
        uploadUrl = "";
        sessionLabel = "";
    }
}
