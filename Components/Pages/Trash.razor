@page "/trash"
@attribute [Authorize]
@inject IDocumentService DocumentService
@inject NavigationManager NavigationManager
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject AuthenticationStateProvider AuthenticationStateProvider
@using DocumentManagementSystem.Models
@using DocumentManagementSystem.Services

<PageTitle>Trash / Recycle Bin - DMS</PageTitle>

<RadzenStack Gap="0.5rem" class="p-2 fade-in-up">
    <!-- Header Area -->
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
            <RadzenIcon Icon="delete" Style="font-size: 1.5rem; color: #0071c1;" />
            <RadzenText TextStyle="TextStyle.H5" class="pagetitle-fontsize" Style="margin: 0; font-weight: bold;">Trash</RadzenText>
        </RadzenStack>
    </RadzenStack>

    <!-- Action Area -->
    <div class="card-body-D px-1 py-1">
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0" class="zero-gap-stack">
            @if (selectedDocuments.Any())
            {
                <RadzenButton Icon="restore" Text="Restore Selected" ButtonStyle="ButtonStyle.Success" 
                              Click="@RestoreSelected" class="search-button me-2" />
                <RadzenButton Image="delete-x.png" Text="Delete Forever" ButtonStyle="ButtonStyle.Danger" 
                              Click="@DeleteSelectedForever" class="search-button" />
            }
            else
            {
                <RadzenText TextStyle="TextStyle.Body2" Style="margin: 0 10px; line-height: 36px;" class="text-muted">
                    Restore documents or delete them permanently.
                </RadzenText>
            }
        </RadzenStack>
    </div>

    <RadzenCard>
        @if (!isLoading && !documents.Any())
        {
             <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Style="padding: 3rem;">
                <img src="delete-x.png" style="width: 4rem; height: 4rem; opacity: 0.5;" />
                <RadzenText TextStyle="TextStyle.H6" Style="color: var(--rz-text-disabled);">Trash is empty</RadzenText>
            </RadzenStack>
        }
        else
        {
            <RadzenDataGrid Data="@documents" TItem="Document" AllowFiltering="true" AllowSorting="true" 
                            AllowPaging="true" PageSize="10" 
                            SelectionMode="DataGridSelectionMode.Multiple" 
                            @bind-Value="@selectedDocuments" class="rz-shadow-sm">
                <Columns>
                    <RadzenDataGridColumn TItem="Document" Width="40px" Sortable="false" Filterable="false">
                        <HeaderTemplate>
                            <RadzenCheckBox TabIndex="-1" TriState="false" TValue="bool" 
                                            Value="@(documents.Any() && selectedDocuments.Count == documents.Count())"
                                            Change="@SelectAll" />
                        </HeaderTemplate>
                        <Template Context="doc">
                            <RadzenCheckBox TabIndex="-1" TriState="false" Value="@selectedDocuments.Contains(doc)" 
                                            TValue="bool" Change="@(selected => ToggleSelection(doc, selected))" />
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="Document" Property="DocumentName" Title="Name" Width="250px">
                        <Template Context="doc">
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                                <RadzenIcon Icon="@GetFileIcon(doc.Extension)" Style="font-size: 1.25rem;" />
                                <RadzenText TextStyle="TextStyle.Body1">@doc.DocumentName</RadzenText>
                            </RadzenStack>
                            <RadzenText TextStyle="TextStyle.Caption" class="text-muted">Deleted: @doc.UpdatedDate.ToString("g")</RadzenText>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="Document" Property="DepartmentName" Title="Department" Width="150px" />
                    <RadzenDataGridColumn TItem="Document" Property="UserName" Title="Deleted By" Width="150px">
                        <Template Context="doc">
                             @doc.UpdatedByName
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="Document" Context="doc" Filterable="false" Sortable="false" 
                                        TextAlign="TextAlign.Center" Width="140px" Title="Actions">
                        <Template Context="doc">
                            <RadzenButton Icon="restore" ButtonStyle="ButtonStyle.Success" Size="ButtonSize.Small" 
                                          Click="@(() => RestoreDocument(doc))" Tooltip="Restore" />
                            <RadzenButton Image="delete-x.png" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" 
                                          Click="@(() => DeleteDocumentForever(doc))" Tooltip="Delete Forever" />
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        }
    </RadzenCard>
</RadzenStack>
