@using DocumentManagementSystem.Services
@using DocumentManagementSystem.Models
@inject IDocumentService DocumentService
@inject DialogService DialogService
@inject NotificationService NotificationService
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider
<RadzenStack Gap="1rem">
    <RadzenText TextStyle="TextStyle.Body1">
        Upload a new version for <strong>@DocumentName</strong>. The current file will be archived.
    </RadzenText>

    @if (isUploading)
    {
        <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
        <RadzenText TextStyle="TextStyle.Body2" class="rz-text-align-center">Uploading and processing...</RadzenText>
    }
    else
    {
        <InputFile OnChange="@LoadFile" class="form-control" />
        @if (file != null)
        {
            <RadzenText TextStyle="TextStyle.Caption" Style="margin-top: 0.5rem;">
                Selected: @file.Name (@FormatFileSize(file.Size))
            </RadzenText>
        }
    }

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem" Style="margin-top: 1rem;">
        <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(false))" Disabled="@isUploading" />
        <RadzenButton Text="Upload New Version" ButtonStyle="ButtonStyle.Primary" Click="@Upload" Disabled="@(file == null || isUploading)" />
    </RadzenStack>
</RadzenStack>
