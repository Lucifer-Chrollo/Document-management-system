@using Radzen
@using Radzen.Blazor
@using DocumentManagementSystem.Models
@using DocumentManagementSystem.Services
@inject IUserGroupService UserGroupService
@inject DialogService DialogService

<RadzenStack Gap="1rem" class="p-2">
    <RadzenText TextStyle="TextStyle.Body1">Share <b>@DocumentName</b> with a group:</RadzenText>

    <RadzenStack Gap="0" class="zero-gap-stack">
        <RadzenDropDown TValue="int" Data="@groups" TextProperty="GroupName" ValueProperty="GroupId" 
                        @bind-Value="@selectedGroupId" Placeholder="Select Group..." Style="width: 100%; height: 36px;" />
    </RadzenStack>

    <RadzenText TextStyle="TextStyle.Subtitle2" Style="margin-top: 0.5rem;">Permissions</RadzenText>
    <RadzenStack Orientation="Orientation.Horizontal" Gap="0" class="zero-gap-stack">
        <RadzenSelectBar @bind-Value="@rights" TValue="int" Style="height: 36px;">
            <Items>
                <RadzenSelectBarItem Text="Read" Value="1" />
                <RadzenSelectBarItem Text="Write" Value="3" />
                <RadzenSelectBarItem Text="Full" Value="7" />
            </Items>
        </RadzenSelectBar>
    </RadzenStack>

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem" class="mt-3">
        <RadzenButton Text="Cancel" Click="@(() => DialogService.Close(null))" ButtonStyle="ButtonStyle.Light" class="search-button" />
        <RadzenButton Text="Share" Click="@OnShare" ButtonStyle="ButtonStyle.Primary" Disabled="@(selectedGroupId == 0)" class="search-button" />
    </RadzenStack>
</RadzenStack>
