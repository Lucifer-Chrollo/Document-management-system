@inherits LayoutComponentBase

<div class="page" style="display: block;">
    <main>
        <ErrorBoundary @ref="errorBoundary">
            <ChildContent>
                @Body
            </ChildContent>
            <ErrorContent Context="ex">
                <div style="padding: 2rem; text-align: center;">
                    <p style="color: #dc3545; font-weight: bold;">Something went wrong.</p>
                    <p style="color: #666; font-size: 0.9rem;">@ex.Message</p>
                    <button onclick="location.reload()" 
                            style="margin-top: 1rem; padding: 0.5rem 1.5rem; background: #667eea; color: white; border: none; border-radius: 8px; cursor: pointer;">
                        Reload Page
                    </button>
                </div>
            </ErrorContent>
        </ErrorBoundary>
    </main>
</div>

@code {
    ErrorBoundary? errorBoundary;

    protected override void OnParametersSet()
    {
        errorBoundary?.Recover();
    }
}
