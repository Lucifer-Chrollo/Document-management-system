@inherits LayoutComponentBase
@inject NavigationManager navigator
@using DocumentManagementSystem.Components.Pages
@using BlazorBootstrap


@inject DialogService DialogService
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Authorization

<div class="wrapper">

<!-- Topbar -->
<div class="bb-top-row px-2 py-1 d-flex flex-wrap justify-content-between align-items-center" style="background-color:#3BAEE5; height:auto;">

    <div class="d-flex justify-content-between align-items-center" style="width: 100%;">
        <!-- Left: Sidebar Toggle, Logo, and Title -->
        <div class="d-flex align-items-center">
            <!-- Sidebar Toggle Button -->
            <Icon Name="IconName.List" role="button" @onclick="ToggleSidebar" style="color:white; font-size:25px;"></Icon>
            <!-- Logo -->
            <img src="/favicon.png" alt="Logo" style="height: 25px; margin-left: 14px;">
            <!-- Title -->
                <span style="color: white; font-size: 16px; font-weight: bold; margin-left: 8px;">DocumentManagementSystem-@CompanyName</span>
        </div>
          
        <!-- Right: Welcome Text and Icons -->
            <div class="d-flex align-items-center">
                    <!-- Branch Badge -->
                <div class="branch-pill d-flex align-items-center me-2">
                    <i class="bi bi-geo-alt-fill branch-icon"></i>
                        <span>@BranchName</span>
                    </div>
              
            <!-- Welcome Text -->
            <AuthorizeView>
                <Authorized>
                    <span style="color:white; font-size:14px;">Welcome, @context.User.Identity?.Name</span>
                </Authorized>
            </AuthorizeView>

            <!-- Icons -->
                <div style="position: relative; display: inline-block;">
                    <a >
                        <img src="/Images/notification.png"
                             class="nav-icon"
                             style="height: 30px; margin-left: 8px;" />
                    </a>

                    @if (UnreadCount > 0)
                    {
                        <span style="
            position: absolute;
            top: -5px;
            right: -5px;
            background: red;
            color: white;
            border-radius: 50%;
            padding: 3px 6px;
            font-size: 10px;
                ">
                            @UnreadCount
                        </span>
                    }
                </div>
                <!-- Icons -->
                <img src="/Images/Help.png" class="nav-icon" style="height: 25px; margin-left: 16px;" @onclick="NavigateHome">
                <img src="/Images/unlock-128.png" class="nav-icon" @onclick="OpenChangePasswordWnd" style="height: 25px; margin-left: 8px;">
                <a @onclick="Logout">
                    <img src="/Images/exit.png" class="nav-icon" style="height: 25px; margin-left: 8px;">
                </a>
                
        </div>
         
    </div>

    
</div>

<!-- Company Logo/Image Above Sidebar -->

<div class="bb-page" >
   
    <!-- Sidebar  -->
    <Sidebar @ref="sidebar"
             Style="background-color:#D3E3FD; color:white;"
             Title=""
             ImageSrc="/favicon.png"
             DataProvider="SidebarDataProvider"
             Width="300"
             WidthUnit="Unit.Px"
             OnItemClick="OnMenuItemClicked" />
       
     <main>      
        <article class="content px-0 py-0 p-0" >
          <div class="main-content">
             <div class="content-area">
                <ErrorBoundary @ref="errorBoundary">
                    <ChildContent>
                        @Body
                    </ChildContent>
                    <ErrorContent Context="ex">
                        <div class="m-4 alert alert-danger" style="border-left: 5px solid red;">
                            <h5>An unexpected error occurred.</h5>
                            <p>@ex.Message</p>
                            <RadzenButton Text="Reload Page" Icon="refresh" ButtonStyle="ButtonStyle.Light" Click="@(() => navigator.NavigateTo(navigator.Uri, forceLoad: true))" />
                        </div>
                    </ErrorContent>
                </ErrorBoundary>
            </div>
          </div>
        </article>
    </main>  
</div>
</div>
<RadzenDialog />
<RadzenNotification />
<RadzenContextMenu />
<RadzenTooltip />

<style>
    .branch-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #1f4f66;
        color: #ffffff;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        width: fit-content;
        margin-right: 70px;
    }

    .branch-icon {
        color: #ffa726;
        font-size: 14px;
    }

    .notif-badge {
        position: absolute;
        top: -6px;
        right: -6px;
        background: red;
        color: white;
        font-size: 10px;
        padding: 3px 6px;
        border-radius: 50%;
    }
    /* Main wrapper covers full screen */
    .wrapper {
        display: flex;
        flex-direction: column;
        height: 100vh;
        width: 100%;
        overflow-x: hidden;
    }

    /* Main content area */
    .main-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow-x: hidden;
        overflow-y: auto;
    }

    /* Page content */
    .content-area {
        flex: 1;
        padding: 0; /* Adjust if needed */
        overflow-x: hidden;
    }

    .bb-sidebar-top-row[b-h9l5f7lx3r] {
        height: 4.5rem;
        background-color: #3BAEE5;
        border-bottom: none;
        border-right: none;

    }

    ::deep .bb-sidebar nav .nav-item a {
        color: rgba(33, 37, 41, 1);
        align-items: center;
        padding: 0.5rem 1rem;
    }

        ::deep .bb-sidebar nav .nav-item a:hover {
            background-color: #3BAEE5;
            color: rgba(33, 37, 41, 1);
            border-radius: 4px;
        }

        ::deep .bb-sidebar nav .nav-item a.active {
            background-color: #D3E3FD;
            color: #3BAEE5;
            font-weight: 600;
            border-radius: 4px;
        }

    ::deep .bb-sidebar nav .nav-item.nav-item-group:has(.nav-link.active) {
        background-color: lightsteelblue;
        padding: 5px;
    }
    ::deep .bb-sidebar nav .nav-item.nav-item-group.active {
        background-color: lightsteelblue;
        padding: 5px;
    }

    .bb-top-row {
        border-bottom: none;
    }

 

    .bb-sidebar-top-row[b-h9l5f7lx3r] {
        height: 56px; /* Fixed height so logo doesn't expand */
        background-color: #D3E3FD;
        border-bottom: none;
        border-right: none;
        margin-top: -10px;
        margin-left: 30px;
    }



    .bb-sidebar-top-row img {
        height: 35px !important;
        width: auto !important; /* Maintain aspect ratio */
        max-width: 200px;
        display: block;
        align-items: center; /* vertical centering */
        justify-content: center; /* horizontal centering */
    }

    .bb-sidebar-top-row a {
        pointer-events: none !important;
    }
   
    .bb-sidebar.collapsed img {
        display: none !important;
    }

    .custom-button {
        border: 1px solid #b7e7fe;
        border-bottom: none;
        border-radius: 3px;
        border-bottom-left-radius: unset;
        border-bottom-right-radius: unset;
        background-color: transparent;
        color: whitesmoke;
        padding: 1px 12px;
        cursor: pointer;
        outline: none;
        position: relative;
        top: 15px;
        flex: 1;
        font-size: 13px;
        height: 28px;
    }

    .custom-button:hover,
    .custom-button:focus {
        background-color: #b7e7fe;
        color: #3baee5;
        border-color: #b7e7fe;
    }
    
</style>

@code {
    int UnreadCount = 0;
    private string CompanyName = "DMS";
    private string BranchName = "Main";
    private bool isAdmin = false;
    private bool hasCheckedAdmin = false;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    Sidebar sidebar = default!;
    ErrorBoundary? errorBoundary;
    IEnumerable<NavItem> visibleNavItems = Enumerable.Empty<NavItem>();
    private bool sidebarExpanded = true;

    private async Task<SidebarDataProviderResult> SidebarDataProvider(SidebarDataProviderRequest request)
    {
        return await Task.FromResult(request.ApplyTo(visibleNavItems));
    }

    protected override async Task OnParametersSetAsync()
    {
        errorBoundary?.Recover();

        // Check admin status from cascading auth state
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            var user = authState.User;
            var newIsAdmin = user.Identity?.IsAuthenticated == true 
                      && (user.IsInRole("Admin") || user.Identity.Name?.Equals("admin", StringComparison.OrdinalIgnoreCase) == true);

            if (newIsAdmin != isAdmin || !hasCheckedAdmin)
            {
                isAdmin = newIsAdmin;
                hasCheckedAdmin = true;
                visibleNavItems = BuildSidebarMenu();

                if (sidebar != null)
                {
                    await sidebar.RefreshDataAsync();
                }
            }
        }
        else if (!hasCheckedAdmin)
        {
            // No auth state yet — show basic menu
            visibleNavItems = BuildSidebarMenu();
            hasCheckedAdmin = true;
        }
    }

    private IEnumerable<NavItem> BuildSidebarMenu()
    {
        var items = new List<NavItem>();

        if (isAdmin)
        {
            // Admin users — only Administration menu
            items.AddRange(new[]
            {
                new NavItem { Id = "100", IconName = IconName.ShieldLockFill, Text = "Administration", IconColor = IconColor.Danger },
                new NavItem { Id = "101", Href = "/admin/users", IconName = IconName.PersonFillGear, Text = "User Management", ParentId = "100", Class = "px-4" },
                new NavItem { Id = "104", Href = "/admin/documents", IconName = IconName.FileEarmarkTextFill, Text = "Document Management", ParentId = "100", Class = "px-4" },
                new NavItem { Id = "102", Href = "/admin/audit", IconName = IconName.ClipboardDataFill, Text = "Audit Logs", ParentId = "100", Class = "px-4" },
                new NavItem { Id = "103", Href = "/admin/sessions", IconName = IconName.QrCode, Text = "Upload Sessions", ParentId = "100", Class = "px-4" },
            });
        }
        else
        {
            // Normal users — DMS Panel + Settings
            items.AddRange(new[]
            {
                new NavItem { Id = "1", IconName = IconName.HddFill, Text = "DMS Panel", IconColor = IconColor.Primary },
                new NavItem { Id = "2", Href = "/ManageDocuments", IconName = IconName.FolderFill, Text = "Documents", ParentId = "1", Class = "px-4", IconColor = IconColor.Primary },
                new NavItem { Id = "3", Href = "/ManageCategories", IconName = IconName.TagsFill, Text = "Category", ParentId = "1", Class = "px-4", IconColor = IconColor.Primary },
                new NavItem { Id = "4", Href = "/ManageUserGroups", IconName = IconName.PeopleFill, Text = "User Groups", ParentId = "1", Class = "px-4", IconColor = IconColor.Primary },

                new NavItem { Id = "30", IconName = IconName.GearFill, Text = "Settings", IconColor = IconColor.Warning },
                new NavItem { Id = "31", Href = "/admin/departments", IconName = IconName.Building, Text = "Departments", ParentId = "30", Class = "px-4" },
                new NavItem { Id = "32", Href = "/admin/locations", IconName = IconName.GeoAltFill, Text = "Locations", ParentId = "30", Class = "px-4" },
            });
        }

        return items;
    }

    private async Task OnMenuItemClicked(NavItem navItem)
    {
        if (!string.IsNullOrEmpty(navItem.Href))
        {
            navigator.NavigateTo(navItem.Href);
        }
    }

    private void ToggleSidebar() => sidebar?.ToggleSidebar();

    private void NavigateHome()
    {
        navigator.NavigateTo("/");
    }

    private async Task OpenChangePasswordWnd()
    {
        // TODO: Wire up password change dialog
    }

    private void Logout()
    {
        navigator.NavigateTo("/Account/Logout", forceLoad: true);
    }
}
